[AmdGpu_Install]
CopyFiles = AmdGpu_CopyFiles
FeatureScore = E1

[AmdGpu_CopyFiles]
amdgpu_wddm.sys

[AmdGpu_Install.HW]
AddReg = AmdGpu_HW_AddReg

[AmdGpu_HW_AddReg]
; No special hardware settings

[AmdGpu_Install.Services]
AddService = amdgpu_wddm, 0x00000002, AmdGpu_Service_Install

[AmdGpu_Service_Install]
DisplayName    = %ServiceDesc%
ServiceType    = 1          ; SERVICE_KERNEL_DRIVER
StartType      = 3          ; SERVICE_DEMAND_START
ErrorControl   = 1          ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\amdgpu_wddm.sys

[Strings]
ProviderString          = "ROCm Open Source"
ManufacturerString      = "Advanced Micro Devices, Inc."
DiskName                = "ROCm Display Driver Disk"
ServiceDesc             = "ROCm Display Driver"

