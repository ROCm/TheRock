;
; amdgpu_wddm.inf - ROCm Display Driver for AMD GPU
;
; WDDM display miniport with POST framebuffer passthrough.
; Registers as Display class, provides escape channel for
; Python compute driver. Supports both display and headless
; (compute-only) AMD GPUs.
;
; Device IDs sourced from Linux kernel amdgpu driver (v6.17).
; Covers Vega (GCN5) through RDNA4 and CDNA1-3 (MI100-MI300).
;

[Version]
Signature   = "$WINDOWS NT$"
Class       = Display
ClassGuid   = {4D36E968-E325-11CE-BFC1-08002BE10318}
Provider    = %ProviderString%
CatalogFile = amdgpu_wddm.cat
DriverVer   = 03/08/2026,10.8.0.700
PnpLockdown = 1

[DestinationDirs]
DefaultDestDir = 13  ; Driver Store

[SourceDisksNames]
1 = %DiskName%

[SourceDisksFiles]
amdgpu_wddm.sys = 1

[Manufacturer]
%ManufacturerString% = AmdGpu, NTamd64.10.0...19041

[AmdGpu.NTamd64.10.0...19041]

; ---- Vega 10 (gfx900) - Radeon RX Vega 56/64, Instinct MI25, Pro WX 8100/9100 ----
%DeviceDesc_Vega10% = AmdGpu_Install, PCI\VEN_1002&DEV_6860
