#!/bin/bash

# Copyright Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

profile_file="/etc/profile.d/rocm-wsl-rocdxg.sh"

remove_profile() {
    # Remove only the profile.d snippet generated by the matching post-install
    # script. User-managed environment settings are left alone.
    if [ -f "$profile_file" ]; then
        rm -f "$profile_file" || true
    fi
}

{% if target == "deb" %}
case "$1" in
    remove|purge)
        remove_profile
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
esac
{% else %}
# RPM passes 0 on final erase and nonzero on upgrade.
if [ "${1:-0}" = "0" ]; then
    remove_profile
fi
{% endif %}

exit 0
