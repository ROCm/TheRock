#!/bin/bash

# Copyright Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

profile_file="/etc/profile.d/rocm-wsl-rocdxg.sh"

is_wsl() {
    # /dev/dxg is the runtime signal that WSL GPU forwarding is available.
    # The environment and kernel string checks cover WSL shells where /dev/dxg
    # is not present yet or GPU forwarding has not been configured.
    [ -e /dev/dxg ] && return 0
    [ -n "${WSL_DISTRO_NAME:-}" ] && return 0
    [ -n "${WSL_INTEROP:-}" ] && return 0
    grep -qiE "microsoft|wsl" /proc/sys/kernel/osrelease 2>/dev/null && return 0
    grep -qiE "microsoft|wsl" /proc/version 2>/dev/null && return 0
    return 1
}

write_profile() {
    # Native packages cannot update already-running shells. Write a profile.d
    # snippet so future shells get the WSL ROCDXG runtime setting.
    mkdir -p "$(dirname "$profile_file")" || {
        echo "Could not create $(dirname "$profile_file")" >&2
        return 0
    }
    if ! cat > "$profile_file" <<'EOF'
# Copyright Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

# Enable ROCR DXG detection for future shells in WSL.
# Leave explicit user settings unchanged.
if [ -z "${HSA_ENABLE_DXG_DETECTION+x}" ]; then
    export HSA_ENABLE_DXG_DETECTION=1
fi
EOF
    then
        echo "Could not write $profile_file" >&2
        return 0
    fi
    chmod 0644 "$profile_file" || true
}

{% if target == "deb" %}
case "$1" in
    configure)
        if is_wsl; then
            write_profile
        fi
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
esac
{% else %}
if is_wsl; then
    write_profile
fi
{% endif %}

exit 0
