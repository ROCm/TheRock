#!/usr/bin/env python3
"""
sign-file — Operator CLI for one-off GPG signing via the remote signing server.

Usage:
    sign-file --server https://<host> --key-id <key> --file <path> [options]

Examples:
    # Detached ASCII signature (e.g. repomd.xml.asc)
    sign-file --server https://10.0.2.45 --key-id therock-release@amd.com \\
              --file repomd.xml --armor

    # Clearsigned output (e.g. DEB InRelease)
    sign-file --server https://10.0.2.45 --key-id therock-release@amd.com \\
              --file Release --clearsign --output InRelease

    # With Phase 2 app token
    sign-file --server https://10.0.2.45 --key-id therock-release@amd.com \\
              --file repomd.xml --armor --token "$SIGNING_TOKEN"

Requirements:
    Python standard library only — no external packages needed.
"""

import sys
import os
import json
import argparse
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError
from base64 import b64encode, b64decode
import ssl


def parse_args():
    parser = argparse.ArgumentParser(
        description='Sign a file using the remote GPG signing server.')

    parser.add_argument('--server', required=True,
        help='Signing server URL (e.g. https://10.0.2.45)')
    parser.add_argument('--file', required=True,
        help='Path to the file to sign')
    parser.add_argument('--output', default='',
        help='Output path for signature. Defaults to <file>.asc or <file>.sig')

    # Simplified API (recommended)
    parser.add_argument('--tier', default='',
        help='Signing tier: dev, nightly, release (maps to GPG key via server config)')
    parser.add_argument('--artifact', default='',
        help='Artifact type: rpm, repodata, deb-release, deb-inrelease '
             '(determines armor/clearsign automatically)')

    # Legacy API (explicit GPG params — still supported)
    parser.add_argument('--key-id', default='', dest='key_id',
        help='GPG key identifier (email or hex key ID). Use --tier instead.')
    parser.add_argument('--armor', action='store_true',
        help='Return ASCII-armored signature. Use --artifact instead.')
    parser.add_argument('--clearsign', action='store_true',
        help='Produce clearsigned output. Use --artifact deb-inrelease instead.')
    parser.add_argument('--digest-algo', default='SHA256', dest='digest_algo',
        help='Digest algorithm: SHA256 or SHA512 (default: SHA256)')
    parser.add_argument('--token', default='',
        help='Pre-shared auth token (Phase 2). Also read from SIGNING_TOKEN env var.')
    parser.add_argument('--no-verify-ssl', action='store_true', dest='no_verify_ssl',
        help='Disable TLS certificate verification (for self-signed certs in Phase 1)')
    parser.add_argument('--timeout', type=int, default=60,
        help='Request timeout in seconds (default: 60)')

    return parser.parse_args()


def build_ssl_context(verify):
    """Build SSL context for the request."""
    ctx = ssl.create_default_context()
    if not verify:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
    return ctx


def sign_file(args):
    # --- Validate argument combinations ---
    using_simplified = bool(args.tier or args.artifact)
    using_legacy     = bool(args.key_id)

    if using_simplified and using_legacy:
        print("Error: Use either --tier/--artifact OR --key-id, not both",
              file=sys.stderr)
        sys.exit(1)

    if using_simplified:
        if not args.tier:
            print("Error: --artifact requires --tier", file=sys.stderr)
            sys.exit(1)
        if not args.artifact:
            print("Error: --tier requires --artifact", file=sys.stderr)
            sys.exit(1)
    elif not using_legacy:
        print("Error: Specify --tier + --artifact (recommended) or --key-id",
              file=sys.stderr)
        sys.exit(1)

    # --- Read input file ---
    if not os.path.exists(args.file):
        print(f"Error: File not found: {args.file}", file=sys.stderr)
        sys.exit(1)

    with open(args.file, 'rb') as f:
        data = f.read()

    if not data:
        print(f"Error: File is empty: {args.file}", file=sys.stderr)
        sys.exit(1)

    print(f"Signing: {args.file} ({len(data)} bytes)")

    # --- Build request ---
    if using_simplified:
        # Simplified API — server resolves all GPG params from config
        payload = {
            'data':     b64encode(data).decode('ascii'),
            'tier':     args.tier,
            'artifact': args.artifact,
        }
        print(f"Tier: {args.tier}  Artifact: {args.artifact}")
    else:
        # Legacy API — explicit GPG params
        payload = {
            'data':        b64encode(data).decode('ascii'),
            'key_id':      args.key_id,
            'digest_algo': args.digest_algo.upper(),
            'armor':       args.armor or args.clearsign,
            'clearsign':   args.clearsign,
        }
        print(f"Key: {args.key_id}")

    server_url = args.server.rstrip('/') + '/sign'
    body = json.dumps(payload).encode('utf-8')

    headers = {
        'Content-Type': 'application/json',
        'User-Agent':   'sign-file/1.0',
    }

    # Phase 2: include token if provided
    token = args.token or os.environ.get('SIGNING_TOKEN', '')
    if token:
        headers['Authorization'] = f'Bearer {token}'

    req = Request(server_url, data=body, headers=headers, method='POST')
    ssl_ctx = build_ssl_context(not args.no_verify_ssl)

    # --- Send request ---
    print(f"Sending to: {server_url}")
    try:
        with urlopen(req, timeout=args.timeout, context=ssl_ctx) as resp:
            result = json.loads(resp.read().decode('utf-8'))
    except HTTPError as e:
        try:
            err_body = json.loads(e.read().decode('utf-8'))
            detail = err_body.get('error', str(e))
        except Exception:
            detail = str(e)

        messages = {
            401: f"Unauthorized — token missing or invalid: {detail}",
            403: f"Forbidden — key '{args.key_id}' not permitted for this caller: {detail}",
            429: f"Rate limit exceeded — try again later: {detail}",
            503: f"Server busy — try again in a moment: {detail}",
            413: f"Request too large: {detail}",
        }
        print(f"Error {e.code}: {messages.get(e.code, detail)}", file=sys.stderr)
        sys.exit(1)
    except URLError as e:
        print(f"Network error: {e.reason}", file=sys.stderr)
        print(f"Is the server reachable at {server_url}?", file=sys.stderr)
        print(f"Are you connected to VPN?", file=sys.stderr)
        sys.exit(1)

    # --- Decode and write signature ---
    if 'signature' not in result:
        print("Error: Server response missing 'signature' field", file=sys.stderr)
        sys.exit(1)

    signature = b64decode(result['signature'])

    # Determine output path
    artifact = getattr(args, 'artifact', '')
    if args.output:
        out_path = args.output
    elif artifact == 'deb-inrelease':
        out_path = os.path.join(os.path.dirname(args.file), 'InRelease')
    elif artifact == 'deb-release':
        out_path = os.path.join(os.path.dirname(args.file), 'Release.gpg')
    elif artifact == 'repodata':
        out_path = args.file + '.asc'
    elif args.clearsign:
        out_path = os.path.splitext(args.file)[0] + '.clearsigned'
    elif args.armor:
        out_path = args.file + '.asc'
    else:
        out_path = args.file + '.sig'

    with open(out_path, 'wb') as f:
        f.write(signature)

    print(f"Signature written to: {out_path} ({len(signature)} bytes)")
    print(f"Key used: {result.get('key_id', args.key_id)}")
    print(f"Algorithm: {result.get('digest_algo', args.digest_algo)}")


def main():
    args = parse_args()
    sign_file(args)


if __name__ == '__main__':
    main()
