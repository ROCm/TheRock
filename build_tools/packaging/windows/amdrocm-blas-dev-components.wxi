  <!-- Contents of directory lib\cmake\rocblas -->
  <ComponentGroup Id="cg_amdrocm_blas_dev_lcr" Directory="amdrocm_blas_dev_lcr">
    <Files Include="$(var.BuildRoot)/math-libs/BLAS/hipBLAS/dist/lib/cmake/rocblas/*.*" />
