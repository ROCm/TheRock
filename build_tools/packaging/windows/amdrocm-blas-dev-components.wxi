<?xml version="1.0" encoding="UTF-8"?>
<Include xmlns="http://wixtoolset.org/schemas/v4/wxs">
<!-- Components -->

  <!-- Contents of directory include -->
  <ComponentGroup Id="cg_amdrocm_blas_dev_i" Directory="amdrocm_blas_dev_i">
