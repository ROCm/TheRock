    <Files Include="$(var.BuildRoot)/math-libs/BLAS/hipBLAS/dist/include/*.*" />
  </ComponentGroup>

  <!-- Contents of directory include\rocblas -->
  <ComponentGroup Id="cg_amdrocm_blas_dev_ir" Directory="amdrocm_blas_dev_ir">
    <Files Include="$(var.BuildRoot)/math-libs/BLAS/hipBLAS/dist/include/rocblas/*.*" />
