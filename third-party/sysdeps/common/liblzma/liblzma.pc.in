prefix=${pcfiledir}/../..
exec_prefix=${pcfiledir}/../../bin
libdir=${pcfiledir}/../../lib
sharedlibdir=${pcfiledir}/../../bin
includedir=${pcfiledir}/../../include

Name: liblzma
Description: xz/liblzma compression library
Version: @PROJECT_VERSION@

Requires:
Libs: -L${libdir} -L${sharedlibdir} @LIBLZMA_IMPORTED_LOCATION@
Cflags: -I${includedir}
