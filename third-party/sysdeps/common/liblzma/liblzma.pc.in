prefix=${pcfiledir}/../..
libdir=${prefix}/lib
includedir=${prefix}/include

Name: liblzma
Description: General purpose data compression library
Version: @PROJECT_VERSION@

Requires:
Cflags: -I${includedir}
Libs: -L${libdir} -lrocm_sysdeps_liblzma ${libdir}/librocm_sysdeps_liblzma.so.5
Libs.private: @PTHREAD_CFLAGS@ @LIBS@
