# Traverse from lib/cmake/FOO -> the directory holding lib
get_filename_component(_IMPORT_PREFIX "${CMAKE_CURRENT_LIST_DIR}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)
if(_IMPORT_PREFIX STREQUAL "/")
  set(_IMPORT_PREFIX "")
endif()

# libblkid (libmount depends on it)
if(NOT TARGET libmount::libblkid)
  add_library(libmount::libblkid SHARED IMPORTED)
  set_target_properties(libmount::libblkid PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${_IMPORT_PREFIX}/include"
    IMPORTED_LOCATION "${_IMPORT_PREFIX}/lib/libblkid.so"
  )
endif()

# libmount (depends on libblkid)
if(NOT TARGET libmount::libmount)
  add_library(libmount::libmount SHARED IMPORTED)
  set_target_properties(libmount::libmount PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${_IMPORT_PREFIX}/include"
    IMPORTED_LOCATION "${_IMPORT_PREFIX}/lib/libmount.so"
    INTERFACE_LINK_LIBRARIES "libmount::libblkid"
  )
endif()

set(_IMPORT_PREFIX)
