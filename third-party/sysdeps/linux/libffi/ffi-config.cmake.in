# Traverse from lib/cmake/ffi -> the directory holding lib
get_filename_component(_IMPORT_PREFIX "${CMAKE_CURRENT_LIST_DIR}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)
get_filename_component(_IMPORT_PREFIX "${_IMPORT_PREFIX}" PATH)
if(_IMPORT_PREFIX STREQUAL "/")
  set(_IMPORT_PREFIX "")
endif()

if(NOT TARGET FFI::ffi)
  add_library(FFI::ffi SHARED IMPORTED)
  set_target_properties(FFI::ffi PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${_IMPORT_PREFIX}/include"
    IMPORTED_LOCATION "${_IMPORT_PREFIX}/lib/libffi.so"
  )
endif()

set(FFI_INCLUDE_DIRS "${_IMPORT_PREFIX}/include")
set(FFI_LIBRARIES FFI::ffi)
set(FFI_VERSION "@PROJECT_VERSION@")

set(_IMPORT_PREFIX)
