From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: akolliasAMD <akollias@amd.com>
Date: Fri, 5 Jun 2026 00:00:00 +0000
Subject: [PATCH 1/2] Apply rocm_sysdeps OUTPUT_NAME to TBB libraries

Override the upstream library names so the produced shared libs are named
librocm_sysdeps_<name>.so. The upstream CMake only sets OUTPUT_NAME on
Windows; on Linux the unprefixed lib<name>.so would otherwise leak into
LD_LIBRARY_PATH and conflict with system TBB.
---
 src/tbb/CMakeLists.txt             | 1 +
 src/tbbmalloc/CMakeLists.txt       | 1 +
 src/tbbmalloc_proxy/CMakeLists.txt | 1 +
 3 files changed, 3 insertions(+)

diff --git a/src/tbb/CMakeLists.txt b/src/tbb/CMakeLists.txt
index 7c083ed..b0dac36 100644
--- a/src/tbb/CMakeLists.txt
+++ b/src/tbb/CMakeLists.txt
@@ -48,6 +48,7 @@ add_library(tbb
     queuing_rw_mutex.cpp)
 
 add_library(TBB::tbb ALIAS tbb)
+set_target_properties(tbb PROPERTIES OUTPUT_NAME "rocm_sysdeps_tbb")
 
 if (WIN32)
     target_sources(tbb PRIVATE tbb.rc)
diff --git a/src/tbbmalloc/CMakeLists.txt b/src/tbbmalloc/CMakeLists.txt
index afefc45..1c64de1 100644
--- a/src/tbbmalloc/CMakeLists.txt
+++ b/src/tbbmalloc/CMakeLists.txt
@@ -26,6 +26,7 @@ if (WIN32)
 endif()
 
 add_library(TBB::tbbmalloc ALIAS tbbmalloc)
+set_target_properties(tbbmalloc PROPERTIES OUTPUT_NAME "rocm_sysdeps_tbbmalloc")
 
 target_compile_definitions(tbbmalloc
     PUBLIC
diff --git a/src/tbbmalloc_proxy/CMakeLists.txt b/src/tbbmalloc_proxy/CMakeLists.txt
index 554ddc8..b8169e7 100644
--- a/src/tbbmalloc_proxy/CMakeLists.txt
+++ b/src/tbbmalloc_proxy/CMakeLists.txt
@@ -25,6 +25,7 @@ if (WIN32)
 endif()
 
 add_library(TBB::tbbmalloc_proxy ALIAS tbbmalloc_proxy)
+set_target_properties(tbbmalloc_proxy PROPERTIES OUTPUT_NAME "rocm_sysdeps_tbbmalloc_proxy")
 
 target_compile_definitions(tbbmalloc_proxy
                            PUBLIC
