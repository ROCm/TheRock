From 57e830e516f43a6d1d9d1014f8c3414164c4951e Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Thu, 2 Apr 2026 21:13:20 +0000
Subject: [PATCH] hipdnn ppc64le

---
 projects/hipdnn/samples/CMakeLists.txt              |  1 +
 .../utilities/CpuFpReferenceValidation.hpp          | 13 +++++++++++++
 .../utilities/pointwise/CpuDeviceExecutor.hpp       |  4 ++++
 .../tests/utilities/TestCpuReferencePointwise.cpp   |  6 +++++-
 4 files changed, 23 insertions(+), 1 deletion(-)

diff --git a/projects/hipdnn/samples/CMakeLists.txt b/projects/hipdnn/samples/CMakeLists.txt
index 1003ef6dac..85e31b7cf1 100644
--- a/projects/hipdnn/samples/CMakeLists.txt
+++ b/projects/hipdnn/samples/CMakeLists.txt
@@ -9,6 +9,7 @@ cmake_minimum_required(VERSION 3.25.2)
 set(CMAKE_POSITION_INDEPENDENT_CODE ON)
 
 project(hipdnn_samples VERSION 0.1.0 LANGUAGES CXX)
+
 include(GNUInstallDirs)
 set(CMAKE_CXX_STANDARD 17)
 
diff --git a/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/CpuFpReferenceValidation.hpp b/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/CpuFpReferenceValidation.hpp
index ac426b2a3c..f793b0bdd8 100644
--- a/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/CpuFpReferenceValidation.hpp
+++ b/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/CpuFpReferenceValidation.hpp
@@ -57,6 +57,18 @@ public:
 
             if(absDiff > threshold)
             {
+#if defined(__powerpc64__) || defined(__PPC64__)
+                // Log error and mark as failed
+                HIPDNN_SDK_LOG_ERROR(
+		  "Validation failed at indices "
+                    << StreamVec(indices) << ": reference value = " << static_cast<float>(refValue)
+		    << ", implementation value = " << static_cast<float>(implValue)
+		    << ", absolute difference = " << static_cast<float>(absDiff)
+		    << ", threshold = " << static_cast<float>(threshold)
+		    << ", difference - threshold = " << static_cast<float>(absDiff - threshold)
+		    << ", (atol=" << static_cast<float>(_absoluteTolerance)
+		    << ", rtol=" << static_cast<float>(_relativeTolerance) << ")");
+#else
                 // Log error and mark as failed
                 HIPDNN_SDK_LOG_ERROR(
                     "Validation failed at indices "
@@ -65,6 +77,7 @@ public:
                     << ", absolute difference = " << absDiff << ", threshold = " << threshold
                     << ", difference - threshold = " << (absDiff - threshold)
                     << ", (atol=" << _absoluteTolerance << ", rtol=" << _relativeTolerance << ")");
+#endif
                 result.store(false, std::memory_order_relaxed);
             }
             return result.load(std::memory_order_relaxed);
diff --git a/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/pointwise/CpuDeviceExecutor.hpp b/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/pointwise/CpuDeviceExecutor.hpp
index 7d8756aa2e..d8093a1ae3 100644
--- a/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/pointwise/CpuDeviceExecutor.hpp
+++ b/projects/hipdnn/test_sdk/include/hipdnn_test_sdk/utilities/pointwise/CpuDeviceExecutor.hpp
@@ -84,7 +84,11 @@ public:
             auto input2Value = input2.getHostValue(input2Indices);
 
             // Apply operation and set output
+#if defined(__powerpc64__) || defined(__PPC64__)
+	    auto result = op(static_cast<float>(input1Value), static_cast<float>(input2Value));
+#else
             auto result = op(input1Value, input2Value);
+#endif
             output.setHostValue(hipdnn_test_sdk::detail::safeConvert<OutputType>(result), indices);
         };
 
diff --git a/projects/hipdnn/test_sdk/tests/utilities/TestCpuReferencePointwise.cpp b/projects/hipdnn/test_sdk/tests/utilities/TestCpuReferencePointwise.cpp
index 054708e008..c5e9dc75c5 100644
--- a/projects/hipdnn/test_sdk/tests/utilities/TestCpuReferencePointwise.cpp
+++ b/projects/hipdnn/test_sdk/tests/utilities/TestCpuReferencePointwise.cpp
@@ -1111,7 +1111,11 @@ protected:
                         auto xCompute = static_cast<ComputeType>(inputVal);
                         auto dyCompute = static_cast<ComputeType>(upstreamGradVal);
                         auto tanhVal = std::tanh(xCompute);
-                        auto localGradient = ComputeType{1} - (tanhVal * tanhVal);
+#if defined(__powerpc64__) || defined(__PPC64__)
+			auto localGradient = ComputeType{1} - static_cast<double>(tanhVal * tanhVal);
+#else
+			auto localGradient = ComputeType{1} - (tanhVal * tanhVal);
+#endif
                         auto downstreamGrad = dyCompute * localGradient;
                         expected.setHostValue(static_cast<OutputType>(downstreamGrad), n, c, h, w);
                     }
-- 
2.47.3

