From f3064d5cc1367e495e9e47e4eca7ae59494671bd Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Thu, 26 Mar 2026 19:38:28 +0000
Subject: [PATCH] rocsparse ppc64le

---
 projects/rocsparse/CMakeLists.txt               | 5 +++++
 projects/rocsparse/clients/tests/CMakeLists.txt | 5 ++++-
 2 files changed, 9 insertions(+), 1 deletion(-)

diff --git a/projects/rocsparse/CMakeLists.txt b/projects/rocsparse/CMakeLists.txt
index 6c87d614b4..7c4efa6403 100644
--- a/projects/rocsparse/CMakeLists.txt
+++ b/projects/rocsparse/CMakeLists.txt
@@ -90,6 +90,11 @@ option(BUILD_WITH_ROCBLAS "Enable building rocSPARSE with rocBLAS" ON)
 option(BUILD_WITH_ROCTX "Enable building rocSPARSE with rocTX" ON)
 option(BUILD_WITH_OFFLOAD_COMPRESS
        "Enable offload compression during compilation" ON)
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
+  set(BUILD_CLIENTS_TESTS OFF)
+  set(BUILD_CLIENTS_BENCHMARKS OFF)
+  file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/clients/matrices")
+endif()
 
 # Clients utilize rocsparse fortran API and a fortran compiler
 if( NOT BUILD_FORTRAN_CLIENTS )
diff --git a/projects/rocsparse/clients/tests/CMakeLists.txt b/projects/rocsparse/clients/tests/CMakeLists.txt
index 7447ba0b62..dc86d2d4d6 100644
--- a/projects/rocsparse/clients/tests/CMakeLists.txt
+++ b/projects/rocsparse/clients/tests/CMakeLists.txt
@@ -420,7 +420,10 @@ endif()
 target_compile_definitions(rocsparse-test PRIVATE GOOGLE_TEST)
 
 # Target compile options
-target_compile_options(rocsparse-test PRIVATE -ffp-contract=on -mfma -Wno-deprecated -Wno-unused-command-line-argument -Wall)
+target_compile_options(rocsparse-test PRIVATE -ffp-contract=on -Wno-deprecated -Wno-unused-command-line-argument -Wall)                                                                       
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64")               
+  target_compile_options(rocsparse-test PRIVATE -mfma)                                                                                                                                        
+endif()                       
 
 # Internal common header
 target_include_directories(rocsparse-test PRIVATE $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/../include>)
-- 
2.47.3

