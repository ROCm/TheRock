From 88f790f784d0a8654cc9bf0376a954451af98505 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Tue, 31 Mar 2026 16:14:24 +0000
Subject: [PATCH] Remove fp16/bf16 workarounds for PPC

---
 projects/hipdnn/CMakeLists.txt         |  8 --------
 projects/hipdnn/samples/CMakeLists.txt |  4 ----
 projects/hipfft/CMakeLists.txt         | 14 --------------
 projects/rocblas/CMakeLists.txt        | 14 --------------
 projects/rocfft/CMakeLists.txt         | 22 ----------------------
 projects/rocsparse/CMakeLists.txt      |  5 -----
 projects/rocwmma/CMakeLists.txt        |  5 -----
 7 files changed, 72 deletions(-)

diff --git a/projects/hipdnn/CMakeLists.txt b/projects/hipdnn/CMakeLists.txt
index 195b8acd96..9cfbe679b1 100644
--- a/projects/hipdnn/CMakeLists.txt
+++ b/projects/hipdnn/CMakeLists.txt
@@ -73,11 +73,6 @@ else()
     )
 endif()
 
-
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-    add_compile_options("-xhip")
-endif()
-
 set(HIPDNN_PLUGIN_ENGINE_SUBDIR "hipdnn_plugins/engines"
     CACHE STRING "Subdirectory for official hipDNN engine plugins"
 )
@@ -205,9 +200,6 @@ list(
     -Wno-error=unused-command-line-argument # Disable error for unused command line arguments
     -Wswitch-default # Warn if a switch statement does not have a default case
 )
-if(${CMAKE_HOST_SYSTEM_PROCESSOR} STREQUAL "ppc64le")
-    list(APPEND HIPDNN_WARNING_COMPILE_OPTIONS -Wno-implicit-float-conversion)
-endif()
 
 add_compile_options(${EXTRA_COMPILE_OPTIONS})
 add_link_options(${EXTRA_LINK_OPTIONS})
diff --git a/projects/hipdnn/samples/CMakeLists.txt b/projects/hipdnn/samples/CMakeLists.txt
index 4ef2347675..85e31b7cf1 100644
--- a/projects/hipdnn/samples/CMakeLists.txt
+++ b/projects/hipdnn/samples/CMakeLists.txt
@@ -10,10 +10,6 @@ set(CMAKE_POSITION_INDEPENDENT_CODE ON)
 
 project(hipdnn_samples VERSION 0.1.0 LANGUAGES CXX)
 
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-    add_definitions(-D_Float16=float)
-endif()
-
 include(GNUInstallDirs)
 set(CMAKE_CXX_STANDARD 17)
 
diff --git a/projects/hipfft/CMakeLists.txt b/projects/hipfft/CMakeLists.txt
index f27441acea..4efdf121ac 100644
--- a/projects/hipfft/CMakeLists.txt
+++ b/projects/hipfft/CMakeLists.txt
@@ -191,20 +191,6 @@ if( BUILD_CLIENTS )
   set( BUILD_CLIENTS_TESTS ON )
 endif()
 
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-  # The Alias: Map the problematic _Float16 to the supported __fp16
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:_Float16=__fp16>")
-
-  # The Driver Flag: Tell Clang it's okay to pass these in registers
-  set(PPC_PFE_FLAGS "-Xclang" "-fallow-half-arguments-and-returns")
-  add_compile_options("$<$<OR:$<COMPILE_LANGUAGE:CXX>,$<COMPILE_LANGUAGE:C>>:${PPC_PFE_FLAGS}>")
-  add_compile_options("$<$<OR:$<COMPILE_LANGUAGE:CXX>,$<COMPILE_LANGUAGE:C>>:-Wno-narrowing>")
-
-  # The Operator Block: Stop the headers from trying to use GPU-only math operators on host
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_OPERATORS__=1>")
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_CONVERSIONS__=1>")
-endif()
-
 # old name for BUILD_CLIENTS_BENCH
 if( BUILD_CLIENTS_RIDER )
   set( BUILD_CLIENTS_BENCH ${BUILD_CLIENTS_RIDER} )
diff --git a/projects/rocblas/CMakeLists.txt b/projects/rocblas/CMakeLists.txt
index 8aea65094b..3cd5d1e340 100644
--- a/projects/rocblas/CMakeLists.txt
+++ b/projects/rocblas/CMakeLists.txt
@@ -33,20 +33,6 @@ unset(ENV{ROCM_BUILD_ID})
 
 project( rocblas LANGUAGES CXX )
 
-# Only apply this on PowerPC architectures
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-  # 1. The Alias: Map the problematic _Float16 to the supported __fp16
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:_Float16=__fp16>")
-
-  # 2. The Driver Flag: Tell Clang it's okay to pass these in registers
-  # Note: Using -Xclang because the driver was complaining earlier
-  set(PPC_PFE_FLAGS "-Xclang" "-fallow-half-arguments-and-returns")
-  add_compile_options("$<$<OR:$<COMPILE_LANGUAGE:CXX>,$<COMPILE_LANGUAGE:C>>:${PPC_PFE_FLAGS}>")
-
-  # 3. The Operator Block: Stop the headers from trying to use GPU-only math operators on host
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_OPERATORS__=1>")
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_CONVERSIONS__=1>")
-endif()
 
 # Append our library helper cmake path and the cmake path for hip (for convenience)
 list( APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_SOURCE_DIR}/cmake )
diff --git a/projects/rocfft/CMakeLists.txt b/projects/rocfft/CMakeLists.txt
index 31a277413e..be8a0b71ae 100644
--- a/projects/rocfft/CMakeLists.txt
+++ b/projects/rocfft/CMakeLists.txt
@@ -182,22 +182,6 @@ rocm_check_target_ids(GPU_TARGETS TARGETS "${GPU_TARGETS}")
 find_package( hip REQUIRED CONFIG PATHS /opt/rocm/lib/cmake/hip/ )
 find_package( hiprtc REQUIRED CONFIG PATHS /opt/rocm/lib/cmake/hiprtc/ )
 
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-  # Add -xhip ONLY to C++ files, ignoring C files like sqlite3.c
-  add_compile_options("$<$<COMPILE_LANGUAGE:CXX>:-xhip>")
-  
-  # The Alias: Map the problematic _Float16 to the supported __fp16
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:_Float16=__fp16>")
-
-  # The Driver Flag: Tell Clang it's okay to pass these in registers
-  set(PPC_PFE_FLAGS "-Xclang" "-fallow-half-arguments-and-returns")
-  add_compile_options("$<$<OR:$<COMPILE_LANGUAGE:CXX>,$<COMPILE_LANGUAGE:C>>:${PPC_PFE_FLAGS}>")
-
-  # The Operator Block: Stop the headers from trying to use GPU-only math operators on host
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_OPERATORS__=1>")
-  add_compile_definitions("$<$<COMPILE_LANGUAGE:CXX>:__HIP_NO_HALF_CONVERSIONS__=1>")
-endif()
-
 # The nvidia backend can be used to compile for CUDA devices.
 # Specify the CUDA prefix in the CUDA_PREFIX variable.
 # CUDA_ARCH (e.g. sm_75) is also required.
@@ -240,12 +224,6 @@ if( BUILD_CLIENTS )
   set( BUILD_CLIENTS_BENCH ON )
   set( BUILD_CLIENTS_SAMPLES ON )
   set( BUILD_CLIENTS_TESTS ON )
-  else()
-  if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-    set( BUILD_CLIENTS_BENCH OFF )
-    set( BUILD_CLIENTS_SAMPLES OFF )
-    set( BUILD_CLIENTS_TESTS OFF )
-  endif()
 endif( )
 
 # old name for BUILD_CLIENTS_BENCH
diff --git a/projects/rocsparse/CMakeLists.txt b/projects/rocsparse/CMakeLists.txt
index 7c4efa6403..6c87d614b4 100644
--- a/projects/rocsparse/CMakeLists.txt
+++ b/projects/rocsparse/CMakeLists.txt
@@ -90,11 +90,6 @@ option(BUILD_WITH_ROCBLAS "Enable building rocSPARSE with rocBLAS" ON)
 option(BUILD_WITH_ROCTX "Enable building rocSPARSE with rocTX" ON)
 option(BUILD_WITH_OFFLOAD_COMPRESS
        "Enable offload compression during compilation" ON)
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-  set(BUILD_CLIENTS_TESTS OFF)
-  set(BUILD_CLIENTS_BENCHMARKS OFF)
-  file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/clients/matrices")
-endif()
 
 # Clients utilize rocsparse fortran API and a fortran compiler
 if( NOT BUILD_FORTRAN_CLIENTS )
diff --git a/projects/rocwmma/CMakeLists.txt b/projects/rocwmma/CMakeLists.txt
index 3ebe322d82..567406b8e5 100644
--- a/projects/rocwmma/CMakeLists.txt
+++ b/projects/rocwmma/CMakeLists.txt
@@ -65,11 +65,6 @@ if( CMAKE_PROJECT_NAME STREQUAL "rocwmma" )
   option( ROCWMMA_CODE_COVERAGE "Build with code coverage flags (clang only)" OFF)
 endif()
 
-if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
-  set( ROCWMMA_BUILD_TESTS OFF )
-  set( ROCWMMA_BUILD_SAMPLES OFF )
-endif()
-
 if( CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT )
   set( CMAKE_INSTALL_PREFIX "/opt/rocm" CACHE PATH "Install path prefix, prepended onto install directories" FORCE )
 endif()
-- 
2.47.3

