From 1a2de0fa0e07e0220ad2bcf744d58ab581f45a79 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Fri, 3 Apr 2026 12:29:36 +0000
Subject: [PATCH] rocblas ppc64le

---
 projects/rocblas/clients/common/cblas_interface.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/projects/rocblas/clients/common/cblas_interface.cpp b/projects/rocblas/clients/common/cblas_interface.cpp
index ef31c58668..9c7d4e46fa 100644
--- a/projects/rocblas/clients/common/cblas_interface.cpp
+++ b/projects/rocblas/clients/common/cblas_interface.cpp
@@ -1553,7 +1553,12 @@ void ref_geam_min_plus(rocblas_operation transA,
             {
                 size_t idxA = TRANSA ? size_t(lda) * m1 + k1 : size_t(lda) * k1 + m1;
                 size_t idxB = TRANSB ? size_t(ldb) * k1 + n1 : size_t(ldb) * n1 + k1;
+#if defined(__powerpc64__) || defined(__PPC64__)
+                auto val = alpha * (A[idxA] + B[idxB]);
+                D[idxD] = (val < (T)D[idxD]) ? (T)val : D[idxD];
+#else
                 D[idxD]     = std::min(alpha * (A[idxA] + B[idxB]), D[idxD]);
+#endif
             }
         }
     }
