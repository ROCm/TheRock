From fc1aeae1019c13f9b9fe72d9acd995f929ee1b2b Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Thu, 14 May 2026 14:35:09 +0000
Subject: [PATCH] Workaround openBLAS build break on POWER

---
 projects/hipsolver/CMakeLists.txt | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/projects/hipsolver/CMakeLists.txt b/projects/hipsolver/CMakeLists.txt
index 3dce2206a1..af96d68e76 100644
--- a/projects/hipsolver/CMakeLists.txt
+++ b/projects/hipsolver/CMakeLists.txt
@@ -207,8 +207,13 @@ if(NOT "${HIP_PLATFORM}" STREQUAL "nvidia")
             list(APPEND LAPACK_CMAKE_ARGS -DCMAKE_CXX_COMPILER=${CMAKE_CXX_COMPILER})
         endif()
 
-        # Force GENERIC target to ensure binaries work on all CPUs
-        list(APPEND LAPACK_CMAKE_ARGS -DTARGET=GENERIC)
+        #TODO: openBLAS arch detection is buggy. GENERIC fails on POWER.
+        if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
+            list(APPEND LAPACK_CMAKE_ARGS -DTARGET=POWER)
+        else()
+            # Force GENERIC target to ensure binaries work on all CPUs
+            list(APPEND LAPACK_CMAKE_ARGS -DTARGET=GENERIC)
+	endif()
 
         # Downgrade incompatible-pointer-types errors to warnings when using Clang
         if(CMAKE_C_COMPILER_ID MATCHES "Clang")
-- 
2.47.3

