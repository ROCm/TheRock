From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrey Kasaurov <andrey.kasaurov@amd.com>
Date: Thu, 1 Jan 2099 00:00:00 +0000
Subject: [PATCH] rocWMMA: remove obsolete compiler flags for Clang 23

Two flags in rocWMMA's CMAKE_CXX_FLAGS are not recognised by the
amd-main compiler branch (Clang 23):

  -Xclang -fallow-half-arguments-and-returns
      Removed upstream; half-type argument passing is now the default.

  -parallel-jobs=4
      Not a valid clang driver option (only exists in clang-linker-wrapper).

Because CMAKE_CXX_FLAGS is included in every try_compile /
check_cxx_compiler_flag probe, unrecognised flags cause "unused
argument" warnings that CMake treats as failures.  This makes
rocm_check_target_ids report no supported targets and check_f8 report
missing FP8 types, ultimately aborting the configure.

Drop both flags.
---
 projects/rocwmma/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/projects/rocwmma/CMakeLists.txt b/projects/rocwmma/CMakeLists.txt
index abcdef1234..5678abcdef 100644
--- a/projects/rocwmma/CMakeLists.txt
+++ b/projects/rocwmma/CMakeLists.txt
@@ -54,7 +54,7 @@ set(CMAKE_CXX_EXTENSIONS OFF)
 #Set Clang C++ flags.
 set(CMAKE_CXX_FLAGS_DEBUG "${CMAKE_CXX_FLAGS_DEBUG} -g -O2") # clang++ crashes without -O2
 set(CMAKE_CXX_FLAGS_MINSIZEREL "${CMAKE_CXX_FLAGS_MINSIZEREL} -O2 -DNDEBUG") # clang++ failed to build the project with the default -Os
-set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} --driver-mode=g++ -Xclang -fallow-half-arguments-and-returns -D__HIP_HCC_COMPAT_MODE__=1 -Wno-format-nonliteral -parallel-jobs=4 -fclang-abi-compat=17")
+set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} --driver-mode=g++ -D__HIP_HCC_COMPAT_MODE__=1 -Wno-format-nonliteral -fclang-abi-compat=17")
 
 # Top level configs
 if( CMAKE_PROJECT_NAME STREQUAL "rocwmma" )
