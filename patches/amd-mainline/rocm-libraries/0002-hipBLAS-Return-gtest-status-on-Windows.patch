From 7c68d1f30ff14cb2caff1c468b89181083cdd507 Mon Sep 17 00:00:00 2001
From: Stella Laurenzo <stellaraccident@gmail.com>
Date: Sun, 3 May 2026 18:38:49 -0700
Subject: [PATCH] hipBLAS: Normalize successful gtest status on Windows

Changes:

- normalize the Windows hipblas-test status to 0 when GTest reports success

- keep std::quick_exit on Windows to bypass post-main DLL cleanup failures

Claude Code
---
 projects/hipblas/clients/gtest/hipblas_gtest_main.cpp | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/projects/hipblas/clients/gtest/hipblas_gtest_main.cpp b/projects/hipblas/clients/gtest/hipblas_gtest_main.cpp
index 788c0f412d..70517e0a00 100644
--- a/projects/hipblas/clients/gtest/hipblas_gtest_main.cpp
+++ b/projects/hipblas/clients/gtest/hipblas_gtest_main.cpp
@@ -350,11 +350,14 @@ int main(int argc, char** argv)
     (void)hipDeviceSynchronize();
     (void)hipDeviceReset();
 
-#ifdef WIN32
-    // Use quick_exit() to bypass C++ static destructors and atexit() handlers.
-    // Post-main cleanup in linked DLLs (HIP runtime) crash in comgr
-    std::quick_exit(status);
-#else
+#ifdef WIN32
+    // RUN_ALL_TESTS can report a non-zero process status on Windows even when
+    // GTest reports all tests passed. Keep quick_exit to bypass static
+    // destructors in linked DLLs after normalizing the success case.
+    if(::testing::UnitTest::GetInstance()->successful())
+        status = 0;
+    std::quick_exit(status);
+#else
     return status;
 #endif
 }
