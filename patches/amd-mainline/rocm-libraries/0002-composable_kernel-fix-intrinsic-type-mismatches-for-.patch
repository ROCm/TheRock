 .../amd_buffer_addressing_builtins.hpp        | 133 ++++++++++--------
 .../include/ck/utility/amd_wmma.hpp           |  29 +++-
 .../include/ck/utility/amd_xdlops.hpp         |  47 ++++++-
 3 files changed, 136 insertions(+), 73 deletions(-)

diff --git a/projects/composablekernel/include/ck/utility/amd_buffer_addressing_builtins.hpp b/projects/composablekernel/include/ck/utility/amd_buffer_addressing_builtins.hpp
index f4ea9c80f1..acc84ebede 100644
--- a/projects/composablekernel/include/ck/utility/amd_buffer_addressing_builtins.hpp
+++ b/projects/composablekernel/include/ck/utility/amd_buffer_addressing_builtins.hpp
@@ -7,6 +7,9 @@
 
 namespace ck {
 
+using uint32x2_t = unsigned int __attribute__((ext_vector_type(2)));
+using uint32x4_t = unsigned int __attribute__((ext_vector_type(4)));
+
 template <typename T>
 union BufferResource
 {
@@ -144,32 +147,35 @@ amd_buffer_load_impl_raw(__amdgpu_buffer_rsrc_t src_wave_buffer_resource,
     }
     else if constexpr(N == 8)
     {
-        int32x2_t tmp = __builtin_amdgcn_raw_buffer_load_b64(src_wave_buffer_resource,
-                                                             src_thread_addr_offset,
-                                                             src_wave_addr_offset,
-                                                             static_cast<index_t>(coherence));
+        int32x2_t tmp = bit_cast<int32x2_t>(
+            __builtin_amdgcn_raw_buffer_load_b64(src_wave_buffer_resource,
+                                                 src_thread_addr_offset,
+                                                 src_wave_addr_offset,
+                                                 static_cast<index_t>(coherence)));
 
         return bit_cast<int8x8_t>(tmp);
     }
     else if constexpr(N == 16)
     {
-        int32x4_t tmp = __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
-                                                              src_thread_addr_offset,
-                                                              src_wave_addr_offset,
-                                                              static_cast<index_t>(coherence));
+        int32x4_t tmp = bit_cast<int32x4_t>(
+            __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
+                                                  src_thread_addr_offset,
+                                                  src_wave_addr_offset,
+                                                  static_cast<index_t>(coherence)));
         return bit_cast<int8x16_t>(tmp);
     }
     else if constexpr(N == 32)
     {
-        int32x4_t tmp0 = __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
-                                                               src_thread_addr_offset,
-                                                               src_wave_addr_offset,
-                                                               static_cast<index_t>(coherence));
-        int32x4_t tmp1 =
+        int32x4_t tmp0 = bit_cast<int32x4_t>(
+            __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
+                                                  src_thread_addr_offset,
+                                                  src_wave_addr_offset,
+                                                  static_cast<index_t>(coherence)));
+        int32x4_t tmp1 = bit_cast<int32x4_t>(
             __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
                                                   src_thread_addr_offset,
                                                   src_wave_addr_offset + 4 * sizeof(int32_t),
-                                                  static_cast<index_t>(coherence));
+                                                  static_cast<index_t>(coherence)));
         vector_type<int32_t, 8> tmp;
 
         tmp.AsType<int32x4_t>()(Number<0>{}) = tmp0;
@@ -179,25 +185,26 @@ amd_buffer_load_impl_raw(__amdgpu_buffer_rsrc_t src_wave_buffer_resource,
     }
     else if constexpr(N == 64)
     {
-        int32x4_t tmp0 = __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
-                                                               src_thread_addr_offset,
-                                                               src_wave_addr_offset,
-                                                               static_cast<index_t>(coherence));
-        int32x4_t tmp1 =
+        int32x4_t tmp0 = bit_cast<int32x4_t>(
+            __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
+                                                  src_thread_addr_offset,
+                                                  src_wave_addr_offset,
+                                                  static_cast<index_t>(coherence)));
+        int32x4_t tmp1 = bit_cast<int32x4_t>(
             __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
                                                   src_thread_addr_offset,
                                                   src_wave_addr_offset + 4 * sizeof(int32_t),
-                                                  static_cast<index_t>(coherence));
-        int32x4_t tmp2 =
+                                                  static_cast<index_t>(coherence)));
+        int32x4_t tmp2 = bit_cast<int32x4_t>(
             __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
                                                   src_thread_addr_offset,
                                                   src_wave_addr_offset + 8 * sizeof(int32_t),
-                                                  static_cast<index_t>(coherence));
-        int32x4_t tmp3 =
+                                                  static_cast<index_t>(coherence)));
+        int32x4_t tmp3 = bit_cast<int32x4_t>(
             __builtin_amdgcn_raw_buffer_load_b128(src_wave_buffer_resource,
                                                   src_thread_addr_offset,
                                                   src_wave_addr_offset + 12 * sizeof(int32_t),
-                                                  static_cast<index_t>(coherence));
+                                                  static_cast<index_t>(coherence)));
 
         vector_type<int32_t, 16> tmp;
 
@@ -274,7 +281,7 @@ amd_buffer_store_impl_raw(const typename vector_type<int8_t, N>::type src_thread
     }
     else if constexpr(N == 8)
     {
-        __builtin_amdgcn_raw_buffer_store_b64(bit_cast<int32x2_t>(src_thread_data),
+        __builtin_amdgcn_raw_buffer_store_b64(bit_cast<uint32x2_t>(src_thread_data),
                                               dst_wave_buffer_resource,
                                               dst_thread_addr_offset,
                                               dst_wave_addr_offset,
@@ -282,7 +289,7 @@ amd_buffer_store_impl_raw(const typename vector_type<int8_t, N>::type src_thread
     }
     else if constexpr(N == 16)
     {
-        __builtin_amdgcn_raw_buffer_store_b128(bit_cast<int32x4_t>(src_thread_data),
+        __builtin_amdgcn_raw_buffer_store_b128(bit_cast<uint32x4_t>(src_thread_data),
                                                dst_wave_buffer_resource,
                                                dst_thread_addr_offset,
                                                dst_wave_addr_offset,
@@ -292,45 +299,51 @@ amd_buffer_store_impl_raw(const typename vector_type<int8_t, N>::type src_thread
     {
         vector_type<int32_t, 8> tmp{bit_cast<int32x8_t>(src_thread_data)};
 
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<0>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset,
-                                               static_cast<index_t>(coherence));
-
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<1>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset + sizeof(int32_t) * 4,
-                                               static_cast<index_t>(coherence));
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<0>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset,
+            static_cast<index_t>(coherence));
+
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<1>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset + sizeof(int32_t) * 4,
+            static_cast<index_t>(coherence));
     }
     else if constexpr(N == 64)
     {
         vector_type<int32_t, 16> tmp{bit_cast<int32x16_t>(src_thread_data)};
 
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<0>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset,
-                                               static_cast<index_t>(coherence));
-
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<1>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset + sizeof(int32_t) * 4,
-                                               static_cast<index_t>(coherence));
-
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<2>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset + sizeof(int32_t) * 8,
-                                               static_cast<index_t>(coherence));
-
-        __builtin_amdgcn_raw_buffer_store_b128(tmp.template AsType<int32x4_t>()[Number<3>{}],
-                                               dst_wave_buffer_resource,
-                                               dst_thread_addr_offset,
-                                               dst_wave_addr_offset + sizeof(int32_t) * 12,
-                                               static_cast<index_t>(coherence));
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<0>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset,
+            static_cast<index_t>(coherence));
+
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<1>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset + sizeof(int32_t) * 4,
+            static_cast<index_t>(coherence));
+
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<2>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset + sizeof(int32_t) * 8,
+            static_cast<index_t>(coherence));
+
+        __builtin_amdgcn_raw_buffer_store_b128(
+            bit_cast<uint32x4_t>(tmp.template AsType<int32x4_t>()[Number<3>{}]),
+            dst_wave_buffer_resource,
+            dst_thread_addr_offset,
+            dst_wave_addr_offset + sizeof(int32_t) * 12,
+            static_cast<index_t>(coherence));
     }
 }
 
diff --git a/projects/composablekernel/include/ck/utility/amd_wmma.hpp b/projects/composablekernel/include/ck/utility/amd_wmma.hpp
index 057687985d..8fcc4ff871 100644
--- a/projects/composablekernel/include/ck/utility/amd_wmma.hpp
+++ b/projects/composablekernel/include/ck/utility/amd_wmma.hpp
@@ -9,6 +9,9 @@
 // TODO: Add arch limitation
 namespace ck {
 
+using sshort8_t  = short __attribute__((ext_vector_type(8)));
+using sshort16_t = short __attribute__((ext_vector_type(16)));
+
 #if defined(__gfx1100__) || defined(__gfx1101__) || defined(__gfx1102__) || \
     defined(__gfx1103__) || defined(__gfx1150__) || defined(__gfx1151__) || \
     defined(__gfx1152__) || defined(__gfx1153__) || defined(__gfx11_generic__)
@@ -59,7 +62,9 @@ struct intrin_wmma_f32_16x16x16_bf16_w32<16, 16>
 #if defined(__gfx11__)
         reg_c.template AsType<float8_t>()(Number<0>{}) =
             __builtin_amdgcn_wmma_f32_16x16x16_bf16_w32(
-                reg_a, reg_b, reg_c.template AsType<float8_t>()[Number<0>{}]);
+                bit_cast<sshort16_t>(reg_a),
+                bit_cast<sshort16_t>(reg_b),
+                reg_c.template AsType<float8_t>()[Number<0>{}]);
 #else
         ignore = reg_a;
         ignore = reg_b;
@@ -106,9 +111,12 @@ struct intrin_wmma_bf16_16x16x16_bf16_w32<16, 16, Opsel>
         // false: D0.[0:15] = result
         // true : D0.[16:31]= result
 #if defined(__gfx11__)
-        reg_c.template AsType<bhalf16_t>()(Number<0>{}) =
+        reg_c.template AsType<bhalf16_t>()(Number<0>{}) = bit_cast<bhalf16_t>(
             __builtin_amdgcn_wmma_bf16_16x16x16_bf16_w32(
-                reg_a, reg_b, reg_c.template AsType<bhalf16_t>()[Number<0>{}], Opsel);
+                bit_cast<sshort16_t>(reg_a),
+                bit_cast<sshort16_t>(reg_b),
+                bit_cast<sshort16_t>(reg_c.template AsType<bhalf16_t>()[Number<0>{}]),
+                Opsel));
 #else
         ignore = reg_a;
         ignore = reg_b;
@@ -179,7 +187,9 @@ struct intrin_wmma_f32_16x16x16_bf16_w64<16, 16>
 #if defined(__gfx11__)
         reg_c.template AsType<float4_t>()(Number<0>{}) =
             __builtin_amdgcn_wmma_f32_16x16x16_bf16_w64(
-                reg_a, reg_b, reg_c.template AsType<float4_t>()[Number<0>{}]);
+                bit_cast<sshort16_t>(reg_a),
+                bit_cast<sshort16_t>(reg_b),
+                reg_c.template AsType<float4_t>()[Number<0>{}]);
 #else
         ignore = reg_a;
         ignore = reg_b;
@@ -226,9 +236,12 @@ struct intrin_wmma_bf16_16x16x16_bf16_w64<16, 16, Opsel>
         // false: D0.[0:15] = result
         // true : D0.[16:31]= result
 #if defined(__gfx11__)
-        reg_c.template AsType<bhalf8_t>()(Number<0>{}) =
+        reg_c.template AsType<bhalf8_t>()(Number<0>{}) = bit_cast<bhalf8_t>(
             __builtin_amdgcn_wmma_bf16_16x16x16_bf16_w64(
-                reg_a, reg_b, reg_c.template AsType<bhalf8_t>()[Number<0>{}], Opsel);
+                bit_cast<sshort16_t>(reg_a),
+                bit_cast<sshort16_t>(reg_b),
+                bit_cast<sshort8_t>(reg_c.template AsType<bhalf8_t>()[Number<0>{}]),
+                Opsel));
 #else
         ignore = reg_a;
         ignore = reg_b;
@@ -306,7 +319,9 @@ struct intrin_wmma_f32_16x16x16_bf16_w32_gfx12<16, 16>
 #if defined(__gfx12__)
         reg_c.template AsType<float8_t>()(Number<0>{}) =
             __builtin_amdgcn_wmma_f32_16x16x16_bf16_w32_gfx12(
-                reg_a, reg_b, reg_c.template AsType<float8_t>()[Number<0>{}]);
+                bit_cast<sshort8_t>(reg_a),
+                bit_cast<sshort8_t>(reg_b),
+                reg_c.template AsType<float8_t>()[Number<0>{}]);
 #else
         ignore = reg_a;
         ignore = reg_b;
