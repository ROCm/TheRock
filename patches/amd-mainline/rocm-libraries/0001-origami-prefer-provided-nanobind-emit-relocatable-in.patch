From 52cc6fe7e3354a9205188d52554d9f5bc839e126 Mon Sep 17 00:00:00 2001
From: David Dixon <david.dixon@amd.com>
Date: Tue, 9 Jun 2026 16:42:09 +0000
Subject: [PATCH] [origami] prefer provided nanobind; emit relocatable
 installed CTestTestfile

Python bindings: try find_package(nanobind CONFIG) first and only fall back
to FetchContent when ORIGAMI_ENABLE_FETCH is set, mirroring how the C++ tests
already resolve Catch2. This lets a super-project (e.g. TheRock) supply its own
hermetic nanobind instead of forcing a build-time GitHub fetch, while standalone
builds keep working via the fetch fallback.

Installed tests: make the generated CTestTestfile.cmake relocatable. Invoke
python3 rather than bare python, and derive LD_LIBRARY_PATH / PYTHONPATH and the
test paths from ${CMAKE_CURRENT_LIST_DIR} instead of baking the build-time
install prefix into the file. Also set SKIP_RETURN_CODE and WORKING_DIRECTORY so
the packaged tests run from wherever the artifact is unpacked.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 shared/origami/python/CMakeLists.txt | 24 +++++++++++++++---------
 shared/origami/tests/CMakeLists.txt  | 18 ++++++++++--------
 2 files changed, 25 insertions(+), 17 deletions(-)

diff --git a/shared/origami/python/CMakeLists.txt b/shared/origami/python/CMakeLists.txt
index e8ac9ca5bd..0c8dda93c6 100644
--- a/shared/origami/python/CMakeLists.txt
+++ b/shared/origami/python/CMakeLists.txt
@@ -31,15 +31,21 @@ endif()
 
 find_package(hip REQUIRED)
 
-include(FetchContent)
-FetchContent_Declare(
-    nanobind
-    GIT_REPOSITORY https://github.com/wjakob/nanobind.git
-    GIT_TAG        v2.0.0
-)
-FetchContent_MakeAvailable(nanobind)
-
-find_package(nanobind CONFIG REQUIRED)
+find_package(nanobind CONFIG QUIET)
+if(NOT nanobind_FOUND)
+    if(ORIGAMI_ENABLE_FETCH)
+        include(FetchContent)
+        FetchContent_Declare(
+            nanobind
+            GIT_REPOSITORY https://github.com/wjakob/nanobind.git
+            GIT_TAG        v2.0.0
+        )
+        FetchContent_MakeAvailable(nanobind)
+        find_package(nanobind CONFIG REQUIRED)
+    else()
+        message(FATAL_ERROR "Failed to find nanobind")
+    endif()
+endif()
 
 if(SKBUILD)
   # When building a wheel via pip/scikit-build-core
diff --git a/shared/origami/tests/CMakeLists.txt b/shared/origami/tests/CMakeLists.txt
index 10db07b6d4..09652ab8dc 100644
--- a/shared/origami/tests/CMakeLists.txt
+++ b/shared/origami/tests/CMakeLists.txt
@@ -38,24 +38,26 @@ set(_ctest_content [=[
 # SPDX-License-Identifier: MIT
 
 # C++ tests
-add_test(origami-tests "../origami-tests")
-set_tests_properties(origami-tests PROPERTIES LABELS "cpp")
+add_test(origami-tests "${CMAKE_CURRENT_LIST_DIR}/../origami-tests")
+set_tests_properties(origami-tests PROPERTIES
+    LABELS "cpp"
+    WORKING_DIRECTORY "${CMAKE_CURRENT_LIST_DIR}"
+)
 
 ]=])
 
 if(ORIGAMI_ENABLE_PYTHON)
     find_package(Python COMPONENTS Interpreter REQUIRED)
-    
-    set(ORIGAMI_INSTALL_LIBDIR "${CMAKE_INSTALL_PREFIX}/${CMAKE_INSTALL_LIBDIR}")
-    set(ORIGAMI_INSTALL_PYTHON_BINDIR "${CMAKE_INSTALL_PREFIX}/${CMAKE_INSTALL_LIBDIR}/python${Python_VERSION_MAJOR}.${Python_VERSION_MINOR}/site-packages")
-    
+
     string(APPEND _ctest_content [=[
 # Python tests (using pytest)
-add_test(origami_python_tests python -m pytest tests/ -v)
+add_test(origami_python_tests python3 -m pytest "${CMAKE_CURRENT_LIST_DIR}/tests" -v)
 
 set_tests_properties(origami_python_tests PROPERTIES
     LABELS "python"
-    ENVIRONMENT "LD_LIBRARY_PATH=@ORIGAMI_INSTALL_LIBDIR@:$ENV{LD_LIBRARY_PATH};PYTHONPATH=@ORIGAMI_INSTALL_PYTHON_BINDIR@:$ENV{PYTHONPATH}"
+    SKIP_RETURN_CODE 5
+    WORKING_DIRECTORY "${CMAKE_CURRENT_LIST_DIR}"
+    ENVIRONMENT "LD_LIBRARY_PATH=${CMAKE_CURRENT_LIST_DIR}/../../@CMAKE_INSTALL_LIBDIR@:$ENV{LD_LIBRARY_PATH};PYTHONPATH=${CMAKE_CURRENT_LIST_DIR}/../../@CMAKE_INSTALL_LIBDIR@/python@Python_VERSION_MAJOR@.@Python_VERSION_MINOR@/site-packages:$ENV{PYTHONPATH}"
 )
 ]=])
 endif()
-- 
