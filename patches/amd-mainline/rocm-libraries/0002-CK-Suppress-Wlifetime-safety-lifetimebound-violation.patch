From 64753008ca133591e1af3cd22798dd19f5a193fc Mon Sep 17 00:00:00 2001
From: therockbot <therockbot@amd.com>
Date: Tue, 12 May 2026 23:32:06 -0400
Subject: [PATCH] [CK] Suppress -Wlifetime-safety compiler errors

The amd-staging compiler introduces -Wlifetime-safety-lifetimebound-violation
and -Wlifetime-safety-intra-tu-suggestions warnings. Combined with -Werror in
Composable Kernel, this causes build failures in tuple.hpp, buffer_view.hpp,
kernel_launch.hpp, and device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp.

Suppress both warnings in the affected headers, and add
-Wno-unknown-warning-option to avoid warnings on compilers that do not
recognize these options yet.

Upstream fix: https://github.com/ROCm/rocm-libraries/pull/7384
---
 .../device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp  | 7 +++++++
 projects/composablekernel/include/ck/utility/tuple.hpp     | 2 ++
 .../include/ck_tile/core/container/tuple.hpp               | 2 ++
 .../include/ck_tile/core/tensor/buffer_view.hpp            | 2 ++
 .../include/ck_tile/host/kernel_launch.hpp                 | 2 ++
 5 files changed, 15 insertions(+)

diff --git a/projects/composablekernel/include/ck/tensor_operation/gpu/device/impl/device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp b/projects/composablekernel/include/ck/tensor_operation/gpu/device/impl/device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp
index 452b0af6c46..e879025c053 100644
--- a/projects/composablekernel/include/ck/tensor_operation/gpu/device/impl/device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp
+++ b/projects/composablekernel/include/ck/tensor_operation/gpu/device/impl/device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp
@@ -3,6 +3,11 @@
 
 #pragma once
 
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wno-unknown-warning-option"
+#pragma clang diagnostic ignored "-Wlifetime-safety-intra-tu-suggestions"
+#pragma clang diagnostic ignored "-Wlifetime-safety-lifetimebound-violation"
+
 #include <functional>
 #include <iostream>
 #include <iterator>
@@ -2233,3 +2238,5 @@ struct DeviceGroupedConvFwdMultipleABD_Xdl_CShuffle
 } // namespace device
 } // namespace tensor_operation
 } // namespace ck
+
+#pragma clang diagnostic pop
diff --git a/projects/composablekernel/include/ck/utility/tuple.hpp b/projects/composablekernel/include/ck/utility/tuple.hpp
index 038a81b992d..0067433839a 100644
