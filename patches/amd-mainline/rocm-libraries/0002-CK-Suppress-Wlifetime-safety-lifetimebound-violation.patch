+++ b/projects/composablekernel/include/ck/tensor_operation/gpu/device/impl/device_grouped_conv_fwd_multiple_abd_xdl_cshuffle.hpp
@@ -3,6 +3,11 @@
 
 #pragma once
 
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wno-unknown-warning-option"
+#pragma clang diagnostic ignored "-Wlifetime-safety-intra-tu-suggestions"
+#pragma clang diagnostic ignored "-Wlifetime-safety-lifetimebound-violation"
+
 #include <functional>
 #include <iostream>
 #include <iterator>
@@ -2233,3 +2238,5 @@ struct DeviceGroupedConvFwdMultipleABD_Xdl_CShuffle
 } // namespace device
 } // namespace tensor_operation
 } // namespace ck
