From cfc2871b4790f960c5fb5ac14ae023a10b1ea607 Mon Sep 17 00:00:00 2001
From: bluedragan <calvins@us.ibm.com>
Date: Thu, 5 Mar 2026 05:33:22 +0000
Subject: [PATCH] hipblaslt: ppc64le

---
 projects/hipblaslt/CMakeLists.txt                           | 4 ++++
 .../hipblaslt/clients/common/include/hipblaslt_math.hpp     | 6 ++++++
 2 files changed, 10 insertions(+)

diff --git a/projects/hipblaslt/CMakeLists.txt b/projects/hipblaslt/CMakeLists.txt
index 166ce3c025..99042b2e66 100644
--- a/projects/hipblaslt/CMakeLists.txt
+++ b/projects/hipblaslt/CMakeLists.txt
@@ -13,6 +13,10 @@ else()
     set(HIPBLASLT_IS_SUBPROJECT TRUE)
 endif()
 
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
+  add_compile_options("-DNO_WARN_X86_INTRINSICS")
+endif()
+
 list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_SOURCE_DIR}/cmake")
 
 include(hipblaslt_shim)
diff --git a/projects/hipblaslt/clients/common/include/hipblaslt_math.hpp b/projects/hipblaslt/clients/common/include/hipblaslt_math.hpp
index f2866fd448..37490a27f3 100644
--- a/projects/hipblaslt/clients/common/include/hipblaslt_math.hpp
+++ b/projects/hipblaslt/clients/common/include/hipblaslt_math.hpp
@@ -30,7 +30,13 @@
 #include <hip/hip_runtime.h>
 #include <hipblaslt/hipblaslt.h>
 #include <hipblaslt/hipblaslt_xfloat32.h>
+#if defined(__powerpc64__) || defined(__PPC64__)
+#ifndef __HIP_DEVICE_COMPILE__
 #include <immintrin.h>
+#endif // __HIP_DEVICE_COMPILE__
+#else
+#include <immintrin.h>
+#endif // defined(__powerpc64__) || defined(__PPC64__)
 #include <type_traits>
 
 /* ============================================================================================ */
