     with timing_context("python_kernel_build_src_co.compile"):
         compiler(str(includeDir), cmdlineArchs, str(kernelPath), objPath)
 
+    # If the compiler compiled per-arch (for sccache compatibility), bundle the
+    # per-arch objects into the fat object that the unbundle step expects.
+    with timing_context("python_kernel_build_src_co.bundle"):
+        per_arch_objs = getattr(compiler, "_pending_per_arch_objs", None)
+        if per_arch_objs is not None:
+            bundler.bundle(per_arch_objs, objPath)
+            for p in per_arch_objs:
+                try:
+                    os.remove(p)
+                except OSError:
+                    pass
+            compiler._pending_per_arch_objs = None
+            compiler._pending_fat_dest = None
