@@ -237,19 +237,37 @@ class Compiler(Component):
     def __call__(self, include_path: str, target_list: List[str], srcPath: str, destPath: str):
         """Compiles a source file into an object file.
 
+        When multiple architectures are requested, compiles one arch at a time
+        so each invocation is a single source → single output call (sccache-cacheable),
+        then bundles the per-arch objects into a fat object at destPath.
+        With a single arch, falls back to a direct single-call compile.
+
         Args:
             include_path: Path appened to "-I" to directory with required include files.
             target_list: List of offload architectures of the form gfxXYZ e.g. gfx942.
-            sercPath: The path to the source file.
-            destPath: Path to the object file output during compilation.
+            srcPath: The path to the source file.
+            destPath: Path to the fat object file output.
         Raises:
             RuntimeError: If the compilation command fails.
         """
-        archFlags = [f"--offload-arch={gfx}" for gfx in target_list]
-        args = [
-            *(self.default_args), "-I", include_path, *archFlags, srcPath, "-c", "-o", destPath
-        ]
-        return _invoke(args, f"Compiling HIP source kernels into objects (.cpp -> .o)")
+        if len(target_list) <= 1:
+            archFlags = [f"--offload-arch={gfx}" for gfx in target_list]
+            args = [*(self.default_args), "-I", include_path, *archFlags, srcPath, "-c", "-o", destPath]
+            return _invoke(args, f"Compiling HIP source kernels into objects (.cpp -> .o)")
+
+        # Compile one arch at a time (sccache-cacheable).
+        destBase = str(destPath).removesuffix(".o")
+        per_arch_objs: List[str] = []
+        for gfx in target_list:
+            perArchDest = f"{destBase}.{gfx}.o"
+            args = [*(self.default_args), "-I", include_path, f"--offload-arch={gfx}", srcPath, "-c", "-o", perArchDest]
+            _invoke(args, f"Compiling HIP source kernels for {gfx} (.cpp -> .o)")
+            per_arch_objs.append(perArchDest)
+
+        # Store per-arch paths on instance so Source.py can bundle them.
+        # Source.py calls compiler() then bundler() — this bridges the two.
+        self._pending_per_arch_objs = per_arch_objs
+        self._pending_fat_dest = destPath
 
 
 class Bundler(Component):
@@ -308,6 +326,36 @@ class Bundler(Component):
 
         return _invoke(args, "Bundling/compressing code object file (.co -> .co)")
 
+    def bundle(self, per_arch_objs: List[str], fatObjPath: str):
+        """Bundles per-arch object files into a single fat HIP object.
+
+        This is the inverse of __call__ (unbundle). Used when compiling one arch
+        at a time for sccache compatibility — the resulting per-arch objects must
+        be re-bundled into a fat object that the rest of the pipeline expects.
+
+        Args:
+            per_arch_objs: List of per-arch .o file paths to bundle.
+            fatObjPath: Output path for the bundled fat object.
+        Raises:
+            RuntimeError: If bundling fails.
+        """
+        # Derive target triples from each per-arch object via -list.
+        all_targets = []
+        for objPath in per_arch_objs:
+            triples = [t for t in self.targets(objPath) if t.strip()]
+            all_targets.extend(triples)
+
+        targets_str = ",".join(all_targets)
+        inputs = [f"--input={p}" for p in per_arch_objs]
+        args = [
+            self._component_path,
+            "--type=o",
+            f"--targets={targets_str}",
+            *inputs,
+            f"--output={fatObjPath}",
+        ]
+        return _invoke(args, f"Bundling per-arch objects into fat object")
+
     def __call__(self, target: str, srcPath: str, destPath: str):
         """Unbundles source code object files using the Clang Offload Bundler.
         Args:
