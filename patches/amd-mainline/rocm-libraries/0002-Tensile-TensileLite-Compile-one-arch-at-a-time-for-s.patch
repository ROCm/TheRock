diff --git a/shared/tensile/Tensile/BuildCommands/SourceCommands.py b/shared/tensile/Tensile/BuildCommands/SourceCommands.py
index a206ec251de..e104cd5bab8 100644
--- a/shared/tensile/Tensile/BuildCommands/SourceCommands.py
+++ b/shared/tensile/Tensile/BuildCommands/SourceCommands.py
@@ -69,6 +69,60 @@ def _computeSourceCodeObjectPath(
     return coPath
 
 
+def _compileSingleArchObjectFile(
+    arch: str,
+    cxxCompiler: str,
+    cxxSrcPath: str,
+    objDestPath: str,
+    outputPath: str,
+    compilerVer: IsaVersion,
+    launcher: List[str],
+    hipFlags: List[str],
+):
+    """Compiles a HIP source file for a single architecture.
+
+    Compiling one arch at a time (rather than all arches in one bundled call)
+    allows sccache to cache each invocation independently. The per-arch objects
+    are later re-bundled into a fat object by _compileSourceObjectFile.
+    """
+    args = launcher + [cxxCompiler] + hipFlags + [f"--offload-arch={arch}"] + [str(cxxSrcPath), "-c", "-o", objDestPath]
+    tPrint(2, f"Compile single-arch object file command: {args}")
+    try:
+        out = subprocess.check_output(args, stderr=subprocess.STDOUT)
+        tPrint(2, f"Output: {out}" if out else "")
+    except subprocess.CalledProcessError as err:
+        raise RuntimeError(
+            f"Error compiling source object file for {arch}: {err.output}\nFailed command: {' '.join(args)}"
+        )
+
+
+def _bundleObjectFiles(bundler: str, perArchObjs: List[tuple], fatObjPath: str):
+    """Bundles per-arch object files into a single fat HIP object.
+
+    Args:
+        bundler: Path to clang-offload-bundler.
+        perArchObjs: List of (triple, objPath) tuples for each arch.
+        fatObjPath: Output path for the bundled fat object.
+    """
+    targets = ",".join(triple for triple, _ in perArchObjs)
+    inputs = [f"--input={path}" for _, path in perArchObjs]
+    args = [
+        bundler,
+        "--type=o",
+        f"--targets={targets}",
+        *inputs,
+        f"--output={fatObjPath}",
+    ]
+    tPrint(2, f"Bundle object files command: {args}")
+    try:
+        out = subprocess.check_output(args, stderr=subprocess.STDOUT)
+        tPrint(2, f"Output: {out}" if out else "")
+    except subprocess.CalledProcessError as err:
+        raise RuntimeError(
+            f"Error bundling object files: {err.output}\nFailed command: {' '.join(args)}"
+        )
+
+
 def _compileSourceObjectFile(
     cmdlineArchs: List[str],
     cxxCompiler: str,
