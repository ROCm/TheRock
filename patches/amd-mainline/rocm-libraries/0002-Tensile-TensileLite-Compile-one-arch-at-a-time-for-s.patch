-            f"Error compiling source object file: {err.output}\nFailed command: {' '.join(args)}"
+    bundler = globalParameters.get("ClangOffloadBundlerPath", "")
+
+    # If only one arch or no bundler available, fall back to the original
+    # single bundled call (not sccache-cacheable, but always correct).
+    if len(cmdlineArchs) <= 1 or not bundler:
+        archFlags = ["--offload-arch=" + arch for arch in cmdlineArchs]
+        args = launcher + [cxxCompiler] + hipFlags + archFlags + [str(cxxSrcPath), "-c", "-o", objDestPath]
+        tPrint(2, f"Compile source object file command: {args}")
+        try:
+            out = subprocess.check_output(args, stderr=subprocess.STDOUT)
+            tPrint(2, f"Output: {out}" if out else "")
+        except subprocess.CalledProcessError as err:
+            raise RuntimeError(
+                f"Error compiling source object file: {err.output}\nFailed command: {' '.join(args)}"
+            )
+        return
+
+    # Compile one arch at a time so each call is sccache-cacheable, then bundle.
+    objDestBase = str(objDestPath).removesuffix(".o")
+    perArchObjs = []
+    for arch in cmdlineArchs:
+        perArchObjPath = f"{objDestBase}.{arch}.o"
+        _compileSingleArchObjectFile(
+            arch, cxxCompiler, cxxSrcPath, perArchObjPath, outputPath, compilerVer, launcher, hipFlags
         )
+        # clang-offload-bundler uses full target triples; derive from the fat
+        # object listing after first arch compilation.
+        perArchObjs.append((arch, perArchObjPath))
+
+    # Resolve arch names to full target triples by compiling the first arch and
+    # listing its triples, then map the remaining arches by gfx suffix.
+    firstObjPath = perArchObjs[0][1]
+    triples = [t for t in _listTargetTriples(bundler, firstObjPath) if re.search("gfx.*$", t)]
+
+    def _matchTriple(arch: str) -> str:
+        for t in triples:
+            if re.search(f"{arch}$", t) or re.search(f"{arch}:", t):
+                return t
+        return f"hipv4-amdgcn-amd-amdhsa--{arch}"
+
+    perArchWithTriples = [(_matchTriple(arch), path) for arch, path in perArchObjs]
+    _bundleObjectFiles(bundler, perArchWithTriples, objDestPath)
+
+    for _, path in perArchObjs:
+        try:
+            os.remove(path)
+        except OSError:
+            pass
 
 
