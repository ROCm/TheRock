     """Round address up to next page boundary."""
-    return (addr + PAGE_SIZE - 1) & ~(PAGE_SIZE - 1)
+    return (addr + page_size - 1) & ~(page_size - 1)
 
 
-def round_down_to_page(addr: int) -> int:
