diff --git a/shared/kpack/python/rocm_kpack/elf/types.py b/shared/kpack/python/rocm_kpack/elf/types.py
index 2d6c6c7347..be9461bf55 100644
--- a/shared/kpack/python/rocm_kpack/elf/types.py
+++ b/shared/kpack/python/rocm_kpack/elf/types.py
@@ -16,9 +16,12 @@ from typing import ClassVar
 # Constants
 # =============================================================================
 
-PAGE_SIZE = 0x1000  # 4KB pages
+PAGE_SIZE = 0x1000  # 4KB pages (x86_64 default)
 ELF_MAGIC = b"\x7fELF"
 
+# ELF machine types (e_machine)
