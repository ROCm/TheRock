@@ -285,6 +285,7 @@ def create_load_segment(
     file_offset: int,
     size: int,
     flags: int = PF_R,
+    page_size: int = PAGE_SIZE,
 ) -> ProgramHeader:
     """Create a PT_LOAD segment.
 
@@ -298,7 +299,7 @@ def create_load_segment(
         New ProgramHeader
     """
     # Verify alignment constraint
-    if (file_offset % PAGE_SIZE) != (vaddr % PAGE_SIZE):
+    if (file_offset % page_size) != (vaddr % page_size):
         raise ValueError(
