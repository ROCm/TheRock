From 1c1dd7f4b0c5704fc18ced112cc42a1c3cd934f0 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Fri, 17 Jul 2026 17:34:56 +0000
Subject: [PATCH] hip-tests: use signed char for arrays with negative values

Plain char is unsigned on PowerPC and ARM, causing a
-Wc++11-narrowing error on negative hex literals like -0x70.
Use signed char explicitly to match the intent.

Co-Authored-By: Claude <noreply@anthropic.com>
---
 .../catch/unit/hip_specific/hip_hc_8pk.cc      | 18 +++++++++---------
 1 file changed, 9 insertions(+), 9 deletions(-)

diff --git a/projects/hip-tests/catch/unit/hip_specific/hip_hc_8pk.cc b/projects/hip-tests/catch/unit/hip_specific/hip_hc_8pk.cc
index 831a9de27e..c9e4c27a76 100644
--- a/projects/hip-tests/catch/unit/hip_specific/hip_hc_8pk.cc
+++ b/projects/hip-tests/catch/unit/hip_specific/hip_hc_8pk.cc
@@ -33,9 +33,9 @@ __global__ void __hip_hc_add8pk_kernel(char4* out, char4 in1, char4 in2) {
  *    - HIP_VERSION >= 5.2
  */
 HIP_TEST_CASE(Unit_Device__hip_hc_add8pk_Sanity_Positive) {
-  const char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x01, 0x10, 0x20, 0x70, 0x7f};
-  const char input2[] = {-0x05, -0x11, -0x20, -0x03, 0x0, 0x30, 0x05, 0x33, 0x0f, 0x7a};
-  const char reference[] = {-0x75, -0x61, -0x50, -0x12, 0x0, 0x31, 0x15, 0x53, 0x7f, -0x07};
+  const signed char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x01, 0x10, 0x20, 0x70, 0x7f};
+  const signed char input2[] = {-0x05, -0x11, -0x20, -0x03, 0x0, 0x30, 0x05, 0x33, 0x0f, 0x7a};
+  const signed char reference[] = {-0x75, -0x61, -0x50, -0x12, 0x0, 0x31, 0x15, 0x53, 0x7f, -0x07};
   LinearAllocGuard<char4> out(LinearAllocs::hipMallocManaged, sizeof(char4));
 
   for (int i = 0; i < 10; ++i) {
@@ -66,9 +66,9 @@ __global__ void __hip_hc_sub8pk_kernel(char4* out, char4 in1, char4 in2) {
  *    - HIP_VERSION >= 5.2
  */
 HIP_TEST_CASE(Unit_Device__hip_hc_sub8pk_Sanity_Positive) {
-  const char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x30, 0x10, 0x33, 0x70, 0x7a};
-  const char input2[] = {-0x05, -0x11, -0x20, -0x03, 0x0, 0x01, 0x05, 0x20, 0x0f, 0x7f};
-  const char reference[] = {-0x6b, -0x3f, -0x10, -0x0c, 0x0, 0x2f, 0x0b, 0x13, 0x61, -0x05};
+  const signed char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x30, 0x10, 0x33, 0x70, 0x7a};
+  const signed char input2[] = {-0x05, -0x11, -0x20, -0x03, 0x0, 0x01, 0x05, 0x20, 0x0f, 0x7f};
+  const signed char reference[] = {-0x6b, -0x3f, -0x10, -0x0c, 0x0, 0x2f, 0x0b, 0x13, 0x61, -0x05};
   LinearAllocGuard<char4> out(LinearAllocs::hipMallocManaged, sizeof(char4));
 
   for (int i = 0; i < 10; ++i) {
@@ -99,9 +99,9 @@ __global__ void __hip_hc_mul8pk_kernel(char4* out, char4 in1, char4 in2) {
  *    - HIP_VERSION >= 5.2
  */
 HIP_TEST_CASE(Unit_Device__hip_hc_mul8pk_Sanity_Positive) {
-  const char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x01, 0x10, 0x20, 0x70, 0x7f};
-  const char input2[] = {0x05, -0x11, 0x22, -0x03, 0x0, 0x30, 0x05, 0x33, 0x0f, 0x7a};
-  const char reference[] = {-0x30, 0x50, -0x60, 0x2d, 0x0, 0x30, 0x50, 0x60, -0x70, -0x7a};
+  const signed char input1[] = {-0x70, -0x50, -0x30, -0x0f, 0x0, 0x01, 0x10, 0x20, 0x70, 0x7f};
+  const signed char input2[] = {0x05, -0x11, 0x22, -0x03, 0x0, 0x30, 0x05, 0x33, 0x0f, 0x7a};
+  const signed char reference[] = {-0x30, 0x50, -0x60, 0x2d, 0x0, 0x30, 0x50, 0x60, -0x70, -0x7a};
   LinearAllocGuard<char4> out(LinearAllocs::hipMallocManaged, sizeof(char4));
 
   for (int i = 0; i < 10; ++i) {
-- 
2.52.0

