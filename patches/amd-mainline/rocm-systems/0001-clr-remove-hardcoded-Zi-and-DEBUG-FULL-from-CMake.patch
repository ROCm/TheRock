From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: TheRock <therock@amd.com>
Date: Wed, 18 Jun 2026 00:00:00 +0000
Subject: [PATCH] clr: remove hardcoded /Zi and /DEBUG:FULL from CMake

ccache and sccache do not support /Zi since it is impossible to track
the separate PDB file generated during compilation. Projects should not
include such flags in their CMake files without a clean way to remove
them.

Upstream fix: https://github.com/ROCm/rocm-systems/pull/6239
---
 projects/clr/hipamd/CMakeLists.txt  | 5 -----
 projects/clr/opencl/CMakeLists.txt  | 6 ------
 2 files changed, 0 insertions(+), 11 deletions(-)

diff --git a/projects/clr/hipamd/CMakeLists.txt b/projects/clr/hipamd/CMakeLists.txt
index ca7abded903..4fcb36d211b 100755
--- a/projects/clr/hipamd/CMakeLists.txt
+++ b/projects/clr/hipamd/CMakeLists.txt
@@ -33,11 +33,6 @@ option(THEROCK_FLAG_STAMP_LIBRARY_GIT_VERSIONS
   "Stamp git revisions into generated library version metadata"
   ON)

-if(MSVC)
-  set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} /Zi")
-  set(CMAKE_SHARED_LINKER_FLAGS "${CMAKE_SHARED_LINKER_FLAGS} /DEBUG:FULL")
-endif()
-
 # Set default HIPCC_BIN_DIR to ${ROCM_PATH}/bin
 set(HIPCC_BIN_DIR "${ROCM_PATH}/bin" CACHE STRING "HIPCC and HIPCONFIG binary directories")

diff --git a/projects/clr/opencl/CMakeLists.txt b/projects/clr/opencl/CMakeLists.txt
index 5b750f9bd99..6d849b4f33b 100644
--- a/projects/clr/opencl/CMakeLists.txt
+++ b/projects/clr/opencl/CMakeLists.txt
@@ -16,12 +16,6 @@ option(BUILD_ICD "Enable building OpenCL ICD Loader" OFF)
 option(EMU_ENV "Enable building for emulation environment" OFF)
 option(ENABLE_ADDRESS_SANITIZER "Option to enable ASAN build" OFF)

-# Add flags to generate PDB files with full symbolic information
-if(MSVC)
-  set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} /Zi")
-  set(CMAKE_SHARED_LINKER_FLAGS "${CMAKE_SHARED_LINKER_FLAGS} /DEBUG:FULL")
-endif()
-
 # Address sanitizer options
 if(ENABLE_ADDRESS_SANITIZER)
   message(STATUS "Building ocltst tests with Address Sanitizer options"
