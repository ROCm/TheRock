From 2af8fe84d81398a2ba2736fcb70a13b6899e146f Mon Sep 17 00:00:00 2001
From: dsalinas <dsalinas@amd.com>
Date: Fri, 8 May 2026 17:14:14 -0500
Subject: [PATCH] [rccl-tests, hip-tests/samples] Deprecate hipconfig: derive
 HIP version from find_package(hip)

Replace hipconfig calls used to determine the HIP version string with
hip_VERSION from find_package(hip), which is already available in scope.
hipconfig is deprecated in favor of CMake-native HIP introspection.

Co-Authored-By: Claude Sonnet 4 <noreply@anthropic.com>
---
 projects/hip-tests/samples/CMakeLists.txt | 24 +++++------------------
 projects/rccl-tests/CMakeLists.txt        |  7 ++-----
 2 files changed, 7 insertions(+), 24 deletions(-)

diff --git a/projects/hip-tests/samples/CMakeLists.txt b/projects/hip-tests/samples/CMakeLists.txt
index e8d6ad3cb9..0b307a8401 100644
--- a/projects/hip-tests/samples/CMakeLists.txt
+++ b/projects/hip-tests/samples/CMakeLists.txt
@@ -26,12 +26,6 @@ if(NOT DEFINED HIP_PATH)
     endif()
 endif()
 
-if(UNIX)
-  set(HIPCONFIG_EXEC "hipconfig")
-else()
-  set(HIPCONFIG_EXEC "hipconfig.bat")
-endif()
-
 # both are not set
 if(NOT DEFINED HIP_PATH AND NOT DEFINED ROCM_PATH)
     if(WIN32)
@@ -47,30 +41,22 @@ if(NOT DEFINED HIP_PATH AND NOT DEFINED ROCM_PATH)
         set(ROCM_PATH "/opt/rocm")
     endif()
 elseif(DEFINED HIP_PATH AND NOT DEFINED ROCM_PATH)
-    if(WIN32)
-        # On Windows, ROCM_PATH is typically the same as HIP_PATH
-        set(ROCM_PATH ${HIP_PATH} CACHE STRING "ROCM Path")
-    else()
-        execute_process(COMMAND ${HIP_PATH}/bin/${HIPCONFIG_EXEC} --rocmpath
-                    OUTPUT_VARIABLE ROCM_PATH
-                    OUTPUT_STRIP_TRAILING_WHITESPACE)
-    endif()
+    set(ROCM_PATH ${HIP_PATH} CACHE STRING "ROCM Path")
 elseif(DEFINED ROCM_PATH AND NOT DEFINED HIP_PATH)
     set(HIP_PATH ${ROCM_PATH})
 endif()
 message(STATUS "HIP_PATH: ${HIP_PATH}")
 message(STATUS "ROCM_PATH: ${ROCM_PATH}")
 
-execute_process(COMMAND ${HIP_PATH}/bin/${HIPCONFIG_EXEC} --version
-                OUTPUT_VARIABLE HIP_VERSION
-                OUTPUT_STRIP_TRAILING_WHITESPACE)
-
-string(REPLACE "." ";" VERSION_LIST ${HIP_VERSION})
+# Use find_package(hip) to get HIP version instead of hipconfig (deprecated).
+find_package(hip REQUIRED CONFIG PATHS "${ROCM_PATH}")
+string(REPLACE "." ";" VERSION_LIST ${hip_VERSION})
 list(GET VERSION_LIST 0 HIP_VERSION_MAJOR)
 list(GET VERSION_LIST 1 HIP_VERSION_MINOR)
 list(GET VERSION_LIST 2 HIP_VERSION_PATCH_GITHASH)
 string(REPLACE "-" ";" VERSION_LIST ${HIP_VERSION_PATCH_GITHASH})
 list(GET VERSION_LIST 0 HIP_VERSION_PATCH)
+set(HIP_VERSION ${hip_VERSION})
 
 
 if(DEFINED ENV{ROCM_LIBPATCH_VERSION})
diff --git a/projects/rccl-tests/CMakeLists.txt b/projects/rccl-tests/CMakeLists.txt
index 09e5a73289..57e5797f3a 100644
--- a/projects/rccl-tests/CMakeLists.txt
+++ b/projects/rccl-tests/CMakeLists.txt
@@ -147,11 +147,8 @@ execute_process(
 message(STATUS "${COMPILER_EXE_NAME} version:    ${compiler_version_string}")
 
 ## Check for HIP version
-find_program(hipconfig_executable hipconfig)
-message(STATUS "hipconfig executable: ${hipconfig_executable}")
-execute_process(
-  COMMAND         bash "-c" "${hipconfig_executable} -v | awk -F\"-\" '{ printf $1 }'"
-  OUTPUT_VARIABLE hip_version_string)
+# Use hip_VERSION from find_package(hip) above instead of hipconfig (deprecated).
+string(REGEX MATCH "^([0-9]+\\.[0-9]+\\.[0-9]+)" hip_version_string "${hip_VERSION}")
 message(STATUS "${COMPILER_EXE_NAME} HIP version:    ${hip_version_string}")
 
 ##Check for ROCm version
-- 
