From cf4c84fe55ba9a88d4949bf7d410efb78942bdc3 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Thu, 26 Mar 2026 19:38:17 +0000
Subject: [PATCH] rocprofiler-sdk ppc64le

---
 projects/rocprofiler-sdk/CMakeLists.txt       |  3 ++
 projects/rocprofiler-sdk/external/elfio       |  2 +-
 projects/rocprofiler-sdk/external/yaml-cpp    |  2 +-
 .../rocprofiler-sdk/source/lib/CMakeLists.txt |  7 ++--
 .../source/lib/rocprofiler-sdk/agent.cpp      | 33 +++++++++++++++++--
 5 files changed, 40 insertions(+), 7 deletions(-)

diff --git a/projects/rocprofiler-sdk/CMakeLists.txt b/projects/rocprofiler-sdk/CMakeLists.txt
index 25f335afb3..32f3f1bf9f 100644
--- a/projects/rocprofiler-sdk/CMakeLists.txt
+++ b/projects/rocprofiler-sdk/CMakeLists.txt
@@ -121,7 +121,10 @@ add_subdirectory(source)
 include(rocprofiler_config_install)
 include(rocprofiler_config_install_roctx)
 include(rocprofiler_config_install_rocpd)
+# rocattach is only supported on x86_64 for now
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64")
 include(rocprofiler_config_install_rocattach)
+endif()
 include(rocprofiler_config_install_tests)
 
 # ROCPROFILER_BUILD_INTEGRATION_TESTS is not a standard option. If not defined, set it as
diff --git a/projects/rocprofiler-sdk/external/elfio b/projects/rocprofiler-sdk/external/elfio
index 8ae6cec5d6..7d30a22fc5 160000
--- a/projects/rocprofiler-sdk/external/elfio
+++ b/projects/rocprofiler-sdk/external/elfio
@@ -1 +1 @@
-Subproject commit 8ae6cec5d60495822ecd57d736f66149da9b1830
+Subproject commit 7d30a22fc5aac06adfe7887ae57f3701b6b5f913
diff --git a/projects/rocprofiler-sdk/external/yaml-cpp b/projects/rocprofiler-sdk/external/yaml-cpp
index 1d8ca1f35e..97d150e98b 160000
--- a/projects/rocprofiler-sdk/external/yaml-cpp
+++ b/projects/rocprofiler-sdk/external/yaml-cpp
@@ -1 +1 @@
-Subproject commit 1d8ca1f35eb3a9c9142462b28282a848e5d29a91
+Subproject commit 97d150e98b77faefa8f1d08f678a2121cfb4f08d
diff --git a/projects/rocprofiler-sdk/source/lib/CMakeLists.txt b/projects/rocprofiler-sdk/source/lib/CMakeLists.txt
index 952a65266f..ef179106bc 100644
--- a/projects/rocprofiler-sdk/source/lib/CMakeLists.txt
+++ b/projects/rocprofiler-sdk/source/lib/CMakeLists.txt
@@ -15,8 +15,11 @@ add_subdirectory(rocprofiler-sdk-roctx)
 set(CMAKE_INSTALL_DEFAULT_COMPONENT_NAME "rocpd")
 add_subdirectory(rocprofiler-sdk-rocpd)
 
-set(CMAKE_INSTALL_DEFAULT_COMPONENT_NAME "rocattach")
-add_subdirectory(rocprofiler-sdk-rocattach)
+# rocattach is only supported on x86_64 for now
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64")
+  set(CMAKE_INSTALL_DEFAULT_COMPONENT_NAME "rocattach")
+  add_subdirectory(rocprofiler-sdk-rocattach)
+endif()
 
 set(CMAKE_INSTALL_DEFAULT_COMPONENT_NAME "tools")
 add_subdirectory(att-tool)
diff --git a/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp b/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
index b1afc9d658..f531868948 100644
--- a/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
+++ b/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
@@ -89,8 +89,14 @@ struct cpu_info
 
     bool is_valid() const
     {
+#if defined(__x86_64__) || defined(_M_X64)
         return !(processor < 0 || family < 0 || model < 0 || physical_id < 0 || core_id < 0 ||
                  apicid < 0 || vendor_id.empty() || model_name.empty());
+#elif defined(__powerpc64__) || defined(__PPC64__)
+        return !(processor < 0 || model_name.empty());
+#else
+        return !(processor < 0 || model_name.empty());
+#endif
     }
 };
 
@@ -172,7 +178,10 @@ parse_cpu_info()
                     }
                 }
 
-                if(itr.find("vendor_id") == 0)
+                if(itr.find("processor") == 0)
+                    info_v.processor = get_stol(value);
+#if defined(__x86_64__) || defined(_M_X64)
+                else if(itr.find("vendor_id") == 0)
                     info_v.vendor_id = value;
                 else if(itr.find("model name") == 0)
                 {
@@ -181,8 +190,6 @@ parse_cpu_info()
                     info_v.model_name =
                         sdk::parse::strip(std::string{info_v.model_name}, " \t\n\v\f\r");
                 }
-                else if(itr.find("processor") == 0)
-                    info_v.processor = get_stol(value);
                 else if(itr.find("cpu family") == 0)
                     info_v.family = get_stol(value);
                 else if(itr.find("model") == 0 && itr.find("model name") != 0)
@@ -193,6 +200,15 @@ parse_cpu_info()
                     info_v.core_id = get_stol(value);
                 else if(itr.find("apicid") == 0)
                     info_v.apicid = get_stol(value);
+#elif defined(__powerpc64__) || defined(__PPC64__)
+                // On POWER, "cpu" holds the model name (e.g. "POWER10 (architected), altivec supported")
+                else if(itr.find("cpu") == 0)
+                {
+                    info_v.model_name = value;
+                    info_v.model_name =
+                        sdk::parse::strip(std::string{info_v.model_name}, " \t\n\v\f\r");
+                }
+#endif
             }
             else
             {
@@ -207,6 +223,17 @@ parse_cpu_info()
             }
         }
 
+#if !defined(__x86_64__) && !defined(_M_X64)
+        // Zero out x86-specific fields that have no equivalent on non-x86 architectures.
+        // Use processor index as a proxy for apicid to allow CPU agent matching.
+        if(info_v.family < 0) info_v.family = 0;
+        if(info_v.model < 0) info_v.model = 0;
+        if(info_v.physical_id < 0) info_v.physical_id = 0;
+        if(info_v.core_id < 0) info_v.core_id = 0;
+        if(info_v.apicid < 0) info_v.apicid = info_v.processor;
+        if(info_v.vendor_id.empty()) info_v.vendor_id = "Unknown";
+#endif
+
         if(info_v.is_valid())
             processor_info.emplace_back(info_v);
         else
-- 
2.47.3

