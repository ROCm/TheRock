From 9b7dcfb64067d15ca816b8c14e19e214594f3fe4 Mon Sep 17 00:00:00 2001
From: therockbot <therockbot@amd.com>
Date: Tue, 30 Jun 2026 01:49:23 -0400
Subject: [PATCH] rocjitsu: log initialization errors to stderr

debug_print() is compiled to nothing in Release builds (NDEBUG defined),
causing initialization failures to be silently swallowed. Add explicit
fprintf(stderr, ...) calls so errors are visible in CI logs.

This helps diagnose issues when:
- Config file is not found
- VM creation fails
---
 .../lib/rocjitsu/src/rocjitsu/kmd/linux/interposer.cpp      | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/emulation/rocjitsu/lib/rocjitsu/src/rocjitsu/kmd/linux/interposer.cpp b/emulation/rocjitsu/lib/rocjitsu/src/rocjitsu/kmd/linux/interposer.cpp
index f20e810e5b..daae648b76 100644
--- a/emulation/rocjitsu/lib/rocjitsu/src/rocjitsu/kmd/linux/interposer.cpp
+++ b/emulation/rocjitsu/lib/rocjitsu/src/rocjitsu/kmd/linux/interposer.cpp
@@ -434,8 +434,11 @@ public:
       in_construction = true;
       auto cfg_file = rocjitsu::rpc_default_config_file_path();
       char cfg_buf[4096]{};
+      fprintf(stderr, "[rocjitsu] Loading config: %s\n", cfg_file.c_str());
       int cfg_fd = static_cast<int>(syscall(SYS_openat, AT_FDCWD, cfg_file.c_str(), O_RDONLY, 0));
       if (cfg_fd < 0) {
+        // Always log to stderr - debug_print is compiled out in Release builds.
+        fprintf(stderr, "[rocjitsu] Config file not found: %s\n", cfg_file.c_str());
         util::Logger::debug_print("rocjitsu: no config file at ", cfg_file);
         in_construction = false;
         return nullptr;
@@ -449,10 +452,13 @@ public:
       while (n > 0 && (cfg_buf[n - 1] == '\n' || cfg_buf[n - 1] == '\r'))
         cfg_buf[--n] = '\0';
       if (rj_vm_create(cfg_buf, RJ_VM_MODE_LOCAL, &rj_vm_) != ROCJITSU_STATUS_SUCCESS) {
+        // Always log to stderr - debug_print is compiled out in Release builds.
+        fprintf(stderr, "[rocjitsu] Failed to create VM from config: %s\n", cfg_buf);
         util::Logger::debug_print("rocjitsu: failed to create VM");
         in_construction = false;
         return nullptr;
       }
+      fprintf(stderr, "[rocjitsu] VM created successfully\n");
 
       // Set up execution plugins based on environment variables.
       if (rj_vm_->soc) {
-- 
