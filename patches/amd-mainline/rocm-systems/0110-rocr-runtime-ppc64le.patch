 .../rocr-runtime/rocrtst/common/hsatimer.cc   |  28 +++++++++++++-----
 .../rocrtst/suites/test_common/CMakeLists.txt |   1 +
 .../core/runtime/amd_gpu_agent.cpp            |  10 +++++--
