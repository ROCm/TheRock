From 88875d9de467a648a648d567de0f0aaf949e90bb Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Fri, 8 May 2026 14:56:38 +0000
Subject: [PATCH] Fix amdsmi Go wrapper when ESMI = OFF

---
 projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.c | 2 ++
 projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.h | 2 ++
 2 files changed, 4 insertions(+)

diff --git a/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.c b/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.c
index 2df131f669..fdcc776230 100644
--- a/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.c
+++ b/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.c
@@ -353,6 +353,7 @@ goamdsmi_status_t go_shim_amdsmiapu_init(goamdsmi_Init_t goamdsmi_Init) {
   return GOAMDSMI_STATUS_SUCCESS;
 }
 ////////////////////////////////////////////////------------CPU------------////////////////////////////////////////////////
+#ifdef ENABLE_ESMI_LIB
 bool goamdsmi_cpu_init() {
   bool cpu_init_success = false;
   if (GOAMDSMI_STATUS_SUCCESS == go_shim_amdsmiapu_init(GOAMDSMI_CPU_INIT)) {
@@ -508,6 +509,7 @@ uint32_t goamdsmi_cpu_core_boostlimit_get(uint32_t thread_index) {
 
   return core_boostlimit_temp;
 }
+#endif  // ENABLE_ESMI_LIB
 
 ////////////////////////////////////////////////------------GPU------------////////////////////////////////////////////////
 bool goamdsmi_gpu_init() {
diff --git a/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.h b/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.h
index 824857cdf5..93fe469c15 100644
--- a/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.h
+++ b/projects/amdsmi/goamdsmi_shim/smiwrapper/amdsmi_go_shim.h
@@ -25,6 +25,7 @@
 
 #include "goamdsmi.h"
 ////////////////////////////////////////////////------------CPU------------////////////////////////////////////////////////
+#ifdef ENABLE_ESMI_LIB
 /**
  *  @brief Go language stub to initialize the AMDSMI library
  *
@@ -167,6 +168,7 @@ uint32_t goamdsmi_cpu_number_of_threads_get();
  *  @retval Zero is returned upon failure.
  */
 uint32_t goamdsmi_cpu_number_of_sockets_get();
+#endif  // ENABLE_ESMI_LIB
 
 ////////////////////////////////////////////////------------GPU------------////////////////////////////////////////////////
 /**
-- 
2.47.3

