From 43a2ef3b6cbcaf2664cd2baf419f577a92a9d2d2 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Tue, 23 Jun 2026 14:15:43 +0000
Subject: [PATCH] Add PPC64 arch config to kpack

---
 shared/kpack/python/rocm_kpack/elf/types.py | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/shared/kpack/python/rocm_kpack/elf/types.py b/shared/kpack/python/rocm_kpack/elf/types.py
index be9461bf55..9c480da2ab 100644
--- a/shared/kpack/python/rocm_kpack/elf/types.py
+++ b/shared/kpack/python/rocm_kpack/elf/types.py
@@ -21,6 +21,7 @@ ELF_MAGIC = b"\x7fELF"
 
 # ELF machine types (e_machine)
 EM_X86_64 = 62
+EM_PPC64 = 21
 
 # ELF header offsets (for direct byte access)
 E_IDENT_OFFSET = 0
@@ -103,6 +104,9 @@ R_X86_64_GLOB_DAT = 6
 R_X86_64_JUMP_SLOT = 7
 R_X86_64_RELATIVE = 8  # Used for PIE/shared library pointer adjustments
 
+# Relocation types (ppc64le)
+R_PPC64_RELATIVE = 22  # Used for PIE/shared library pointer adjustments
+
 # Dynamic section tags (d_tag)
 DT_NULL = 0
 DT_NEEDED = 1
@@ -576,7 +580,8 @@ class ArchConfig:
 
 
 _ARCH_CONFIGS: dict[int, ArchConfig] = {
-    EM_X86_64: ArchConfig(page_size=0x1000, r_relative=R_X86_64_RELATIVE),
+    EM_X86_64: ArchConfig(page_size=4096, r_relative=R_X86_64_RELATIVE),
+    EM_PPC64: ArchConfig(page_size=64 * 1024, r_relative=R_PPC64_RELATIVE),
 }
 
 def get_arch_config(e_machine: int) -> ArchConfig:
-- 
2.52.0

