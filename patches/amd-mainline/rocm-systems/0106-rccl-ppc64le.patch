From 97a7e8c1de17f7c4a0c2c488dbdf99ae8681e6f6 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Thu, 2 Apr 2026 21:15:16 +0000
Subject: [PATCH] rccl ppc64le

---
 projects/rccl/src/init.cc | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/projects/rccl/src/init.cc b/projects/rccl/src/init.cc
index 174eec546a..cc49380702 100644
--- a/projects/rccl/src/init.cc
+++ b/projects/rccl/src/init.cc
@@ -75,7 +75,9 @@
 #include "msccl/msccl_status.h"
 #include "latency_profiler/CollTrace.h"
 #include "latency_profiler/CollTraceFunc.h"
-#include  <cpuid.h>
+#if defined(__x86_64__) || defined(__i386__)
+#include <cpuid.h>
+#endif
 
 #ifndef STR2
   #define STR2(v) #v
@@ -268,8 +270,12 @@ static ncclResult_t ncclInit() {
     INFO(NCCL_INIT, "Kernel version: %s", verStr);
     if (strstr(verStr, "cray") == NULL) {
       unsigned int eax, ebx, ecx, edx;
+#if defined(__x86_64__) || defined(__i386__)
       if (!__get_cpuid(1, &eax, &ebx, &ecx, &edx))
         ecx = 0; // cpuid not supported
+#else
+      	ecx=0;
+#endif
       NCCLCHECK(ncclTopoGetStrFromSys("/sys/devices/virtual/dmi/id", "bios_version", strValue));
       // Check BIOS string and hypervisor presence on ecx bit 31
       if (strncmp("Hyper-V UEFI Release", strValue, 20) != 0 && (ecx & (1u << 31)) == 0) {
-- 
