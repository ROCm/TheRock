From a4fde6479939f5d8337a09f0a155b84c422d93e0 Mon Sep 17 00:00:00 2001
From: berichar <ben.richard@amd.com>
Date: Wed, 11 Mar 2026 11:27:56 -0400
Subject: [PATCH] hip-tests: ppc64le

---
 projects/hip-tests/catch/CMakeLists.txt      | 23 +++++++++++---------
 projects/hip-tests/catch/unit/CMakeLists.txt | 12 +++++-----
 2 files changed, 20 insertions(+), 15 deletions(-)

diff --git a/projects/hip-tests/catch/CMakeLists.txt b/projects/hip-tests/catch/CMakeLists.txt
index ecd1cca3e9..9cc7c9af7c 100644
--- a/projects/hip-tests/catch/CMakeLists.txt
+++ b/projects/hip-tests/catch/CMakeLists.txt
@@ -216,16 +216,19 @@ if(WIN32)
 endif()
 
 if(HIP_PLATFORM STREQUAL "amd")
-    if(WIN32)
-        set(win_disable_warnings ${win_disable_warnings} -Wno-ignored-attributes -Wno-microsoft-cast)
-        # Windows for some reason does not honor the `CMAKE_CXX_STANDARD` we set initially in the file
-        # Which results in errors about missing headers etc
-        set(win_cxx_standard -std=c++17)
-    endif()
-    add_compile_options(${HIP_PATH_OPT} ${win_cxx_standard} -x hip -Wall -Wextra -Wvla -Wno-deprecated -Wno-option-ignored -Wno-unused-parameter ${win_disable_warnings})
-    if(CMAKE_BUILD_TYPE STREQUAL "Release")
-        add_compile_options(-O3)
-    endif()
+  if(WIN32)
+    set(win_disable_warnings ${win_disable_warnings} -Wno-ignored-attributes -Wno-microsoft-cast)
+    # Windows for some reason does not honor the `CMAKE_CXX_STANDARD` we set initially in the file
+    # Which results in errors about missing headers etc
+    set(win_cxx_standard -std=c++17)
+  endif()
+  add_compile_options(${HIP_PATH_OPT} ${win_cxx_standard} -x hip -Wall -Wextra -Wvla -Wno-deprecated -Wno-option-ignored -Wno-unused-parameter ${win_disable_warnings})
+  if(CMAKE_BUILD_TYPE STREQUAL "Release")
+    add_compile_options(-O3)
+  endif()
+  if(CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
+      add_compile_options(-Wno-narrowing)
+  endif()
 endif()
 
 # Turn off CMAKE_HIP_ARCHITECTURES Feature if cmake version is 3.21+
diff --git a/projects/hip-tests/catch/unit/CMakeLists.txt b/projects/hip-tests/catch/unit/CMakeLists.txt
index 9a37ac90d5..341a2f9751 100644
--- a/projects/hip-tests/catch/unit/CMakeLists.txt
+++ b/projects/hip-tests/catch/unit/CMakeLists.txt
@@ -51,11 +51,13 @@ add_subdirectory(threadfence)
 add_subdirectory(virtualMemoryManagement)
 # TODO Rock build failures
 if(UNIX)
-    add_subdirectory(atomics)
-    add_subdirectory(math)
-    # TODO compute build failures
-    add_subdirectory(deviceLib)
-    add_subdirectory(syncthreads)
+  add_subdirectory(atomics)
+  if(NOT CMAKE_SYSTEM_PROCESSOR MATCHES "ppc64le")
+      add_subdirectory(math)
+      # TODO compute build failures
+      add_subdirectory(deviceLib)
+  endif()
+  add_subdirectory(syncthreads)
 endif()
 if(HIP_PLATFORM STREQUAL "amd")
     add_subdirectory(callback)
-- 
2.50.1 (Apple Git-155)

