From cf593a464879773070ed9ebe909fa3a61a9e23a3 Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Tue, 17 Mar 2026 13:56:01 -0400
Subject: [PATCH] Update rocprofiler-sdk CPU detection to work with POWER

---
 .../source/lib/rocprofiler-sdk/agent.cpp      | 33 +++++++++++++++++--
 1 file changed, 30 insertions(+), 3 deletions(-)

diff --git a/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp b/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
index 70f9bb5ff2..15ba2df297 100644
--- a/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
+++ b/projects/rocprofiler-sdk/source/lib/rocprofiler-sdk/agent.cpp
@@ -89,8 +89,14 @@ struct cpu_info
 
     bool is_valid() const
     {
+#if defined(__x86_64__) || defined(_M_X64)
         return !(processor < 0 || family < 0 || model < 0 || physical_id < 0 || core_id < 0 ||
                  apicid < 0 || vendor_id.empty() || model_name.empty());
+#elif defined(__powerpc64__) || defined(__PPC64__)
+        return !(processor < 0 || model_name.empty());
+#else
+        return !(processor < 0 || model_name.empty());
+#endif
     }
 };
 
@@ -172,7 +178,10 @@ parse_cpu_info()
                     }
                 }
 
-                if(itr.find("vendor_id") == 0)
+                if(itr.find("processor") == 0)
+                    info_v.processor = get_stol(value);
+#if defined(__x86_64__) || defined(_M_X64)
+                else if(itr.find("vendor_id") == 0)
                     info_v.vendor_id = value;
                 else if(itr.find("model name") == 0)
                 {
@@ -181,8 +190,6 @@ parse_cpu_info()
                     info_v.model_name =
                         sdk::parse::strip(std::string{info_v.model_name}, " \t\n\v\f\r");
                 }
-                else if(itr.find("processor") == 0)
-                    info_v.processor = get_stol(value);
                 else if(itr.find("cpu family") == 0)
                     info_v.family = get_stol(value);
                 else if(itr.find("model") == 0 && itr.find("model name") != 0)
@@ -193,6 +200,15 @@ parse_cpu_info()
                     info_v.core_id = get_stol(value);
                 else if(itr.find("apicid") == 0)
                     info_v.apicid = get_stol(value);
+#elif defined(__powerpc64__) || defined(__PPC64__)
+                // On POWER, "cpu" holds the model name (e.g. "POWER10 (architected), altivec supported")
+                else if(itr.find("cpu") == 0)
+                {
+                    info_v.model_name = value;
+                    info_v.model_name =
+                        sdk::parse::strip(std::string{info_v.model_name}, " \t\n\v\f\r");
+                }
+#endif
             }
             else
             {
@@ -207,6 +223,17 @@ parse_cpu_info()
             }
         }
 
+#if !defined(__x86_64__) && !defined(_M_X64)
+        // Zero out x86-specific fields that have no equivalent on non-x86 architectures.
+        // Use processor index as a proxy for apicid to allow CPU agent matching.
+        if(info_v.family < 0) info_v.family = 0;
+        if(info_v.model < 0) info_v.model = 0;
+        if(info_v.physical_id < 0) info_v.physical_id = 0;
+        if(info_v.core_id < 0) info_v.core_id = 0;
+        if(info_v.apicid < 0) info_v.apicid = info_v.processor;
+        if(info_v.vendor_id.empty()) info_v.vendor_id = "Unknown";
+#endif
+
         if(info_v.is_valid())
             processor_info.emplace_back(info_v);
         else
-- 
