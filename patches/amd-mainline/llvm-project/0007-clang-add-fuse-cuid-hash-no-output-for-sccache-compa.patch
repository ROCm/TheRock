From aa451e1fe6a793394d6733051b1778633063ae96 Mon Sep 17 00:00:00 2001
From: chiranjeevipattigidi <chiranjeevi.pattigidi@amd.com>
Date: Tue, 15 Jul 2026 00:00:00 +0000
Subject: [PATCH] [clang] Add -fuse-cuid=hash-no-output for sccache
 compatibility

sccache deliberately excludes -o from its cache key so that the same
compilation to different output directories produces a cache hit.  The
default -fuse-cuid=hash mode includes ALL non-input args (including -o)
in the CUID hash, which creates a mismatch:

  TU A: -o build/CMakeFiles/foo.dir/a.hip.o  → CUID_A
  TU B: -o build/CMakeFiles/foo.dir/b.hip.o  → CUID_B  (different -o)

sccache sees both as the SAME cache key (no -o in its key) and returns
TU A's cached object for TU B.  But TU B's object carries __hip_cuid_A
(from the cache hit), while the RDC linker expects __hip_cuid_B.
Result: duplicate-symbol link failure (ROCm/TheRock#748).

The new mode 'hash-no-output' computes the CUID identically to 'hash'
but skips the -o / --output argument, aligning the CUID hash with
sccache's cache key.  On a warm sccache hit the two TUs still get
distinct CUID values because their relative output paths differ — the
remaining args (source file, offload-arch, include paths, etc.) differ
between TUs.

Usage:
  clang++ -fuse-cuid=hash-no-output -fgpu-rdc --offload-arch=gfx942 \
          -c kernel.hip -o build/kernel.hip.o

Or via CMake configure:
  -DCMAKE_HIP_FLAGS="-fuse-cuid=hash-no-output"

This eliminates the need for an external cuid_launcher.py wrapper when
building with sccache.
---
 clang/include/clang/Driver/Driver.h  |  2 +-
 clang/lib/Driver/Driver.cpp          | 16 +++++++++++++---
 2 files changed, 14 insertions(+), 4 deletions(-)

diff --git a/clang/include/clang/Driver/Driver.h b/clang/include/clang/Driver/Driver.h
index 1234567890ab..abcdef123456 100644
--- a/clang/include/clang/Driver/Driver.h
+++ b/clang/include/clang/Driver/Driver.h
@@ -76,7 +76,7 @@ enum ModuleHeaderMode {
 /// compilation units.
 class CUIDOptions {
 public:
-  enum class Kind { Hash, Random, Fixed, None, Invalid };
+  enum class Kind { Hash, HashNoOutput, Random, Fixed, None, Invalid };

   CUIDOptions() = default;
   CUIDOptions(llvm::opt::DerivedArgList &Args, const Driver &D);
diff --git a/clang/lib/Driver/Driver.cpp b/clang/lib/Driver/Driver.cpp
index fedcba987654..123456789abc 100644
--- a/clang/lib/Driver/Driver.cpp
+++ b/clang/lib/Driver/Driver.cpp
@@ -138,7 +138,8 @@ CUIDOptions::CUIDOptions(llvm::opt::DerivedArgList &Args, const Driver &D)
     UseCUID = llvm::StringSwitch<Kind>(UseCUIDStr)
                   .Case("hash", Kind::Hash)
                   .Case("random", Kind::Random)
+                  .Case("hash-no-output", Kind::HashNoOutput)
                   .Case("none", Kind::None)
                   .Default(Kind::Invalid);
     if (UseCUID == Kind::Invalid)
@@ -156,16 +157,25 @@ std::string CUIDOptions::getCUID(StringRef InputFile,
   std::string CUID = FixedCUID.str();
   if (CUID.empty()) {
     if (UseCUID == Kind::Random)
       CUID = llvm::utohexstr(llvm::sys::Process::GetRandomNumber(),
                              /*LowerCase=*/true);
-    else if (UseCUID == Kind::Hash) {
+    else if (UseCUID == Kind::Hash || UseCUID == Kind::HashNoOutput) {
       llvm::MD5 Hasher;
       llvm::MD5::MD5Result Hash;
       Hasher.update(InputFile);
       for (auto *A : Args) {
         if (A->getOption().matches(options::OPT_INPUT))
           continue;
+        // hash-no-output: skip -o so the CUID hash aligns with sccache's
+        // cache key (sccache excludes -o when computing its key).  Without
+        // this, two TUs that differ only in -o collapse to the same sccache
+        // entry but carry different __hip_cuid_ symbols, causing duplicate-
+        // symbol errors at RDC link time (ROCm/TheRock#748).
+        if (UseCUID == Kind::HashNoOutput &&
+            (A->getOption().matches(options::OPT_o) ||
+             A->getOption().matches(options::OPT__output)))
+          continue;
         Hasher.update(A->getAsString(Args));
       }
       Hasher.final(Hash);
       CUID = llvm::utohexstr(Hash.low(), /*LowerCase=*/true);
     }
   }
   return CUID;
