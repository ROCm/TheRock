From c5d05fe7292491683c3ad21059cee4352ae47eed Mon Sep 17 00:00:00 2001
From: benrichard-amd <ben.richard@amd.com>
Date: Mon, 13 Apr 2026 17:15:12 +0000
Subject: [PATCH] Fix fp16 comparison on targets using SoftPromoteHalf

When both comparison operators are fp16 on a target using
SoftPromoteHalf (e.g. PPC), the node falls into SoftPromoteHalfOperand
which had no BR_CC case, causing a fatal error.

This commit fixes this by adding SoftPromoteHalfOp_BR_CC, modeled on
the existing SoftPromoteHalfOp_SELCT_CC handler. Both lhs and rhs are
promoted to the next larger FP type and the node is rebuilt.
---
 .../SelectionDAG/LegalizeFloatTypes.cpp       | 23 +++++++++++++++++++
 llvm/lib/CodeGen/SelectionDAG/LegalizeTypes.h |  1 +
 2 files changed, 24 insertions(+)

diff --git a/llvm/lib/CodeGen/SelectionDAG/LegalizeFloatTypes.cpp b/llvm/lib/CodeGen/SelectionDAG/LegalizeFloatTypes.cpp
index 25f4f75eaede..01e7bf604816 100644
--- a/llvm/lib/CodeGen/SelectionDAG/LegalizeFloatTypes.cpp
+++ b/llvm/lib/CodeGen/SelectionDAG/LegalizeFloatTypes.cpp
@@ -3171,6 +3171,7 @@ bool DAGTypeLegalizer::SoftPromoteHalfOperand(SDNode *N, unsigned OpNo) {
                        "operand!");
 
   case ISD::BITCAST:    Res = SoftPromoteHalfOp_BITCAST(N); break;
+  case ISD::BR_CC:      Res = SoftPromoteHalfOp_BR_CC(N, OpNo); break;
   case ISD::FAKE_USE:
     Res = SoftPromoteHalfOp_FAKE_USE(N, OpNo);
     break;
@@ -3309,6 +3310,28 @@ SDValue DAGTypeLegalizer::SoftPromoteHalfOp_FP_TO_XINT_SAT(SDNode *N) {
                      N->getOperand(1));
 }
 
+SDValue DAGTypeLegalizer::SoftPromoteHalfOp_BR_CC(SDNode *N, unsigned OpNo) {
+  // BR_CC: (chain, cc, lhs, rhs, dest). LHS/RHS are operands 2 and 3.
+  assert(OpNo == 2 && "Can only soften the comparison values");
+  SDValue Op0 = N->getOperand(2); // LHS
+  SDValue Op1 = N->getOperand(3); // RHS
+  SDLoc dl(N);
+
+  EVT SVT = Op0.getValueType();
+  EVT NVT = TLI.getTypeToTransformTo(*DAG.getContext(), SVT);
+
+  Op0 = GetSoftPromotedHalf(Op0);
+  Op1 = GetSoftPromotedHalf(Op1);
+
+  // Promote to the larger FP type.
+  auto PromotionOpcode = GetPromotionOpcode(SVT, NVT);
+  Op0 = DAG.getNode(PromotionOpcode, dl, NVT, Op0);
+  Op1 = DAG.getNode(PromotionOpcode, dl, NVT, Op1);
+
+  return DAG.getNode(ISD::BR_CC, dl, N->getValueType(0), N->getOperand(0),
+                     N->getOperand(1), Op0, Op1, N->getOperand(4));
+}
+
 SDValue DAGTypeLegalizer::SoftPromoteHalfOp_SELECT_CC(SDNode *N,
                                                       unsigned OpNo) {
   assert(OpNo == 0 && "Can only soften the comparison values");
diff --git a/llvm/lib/CodeGen/SelectionDAG/LegalizeTypes.h b/llvm/lib/CodeGen/SelectionDAG/LegalizeTypes.h
index a8ffb66a9d91..f8bbc8cbac9b 100644
--- a/llvm/lib/CodeGen/SelectionDAG/LegalizeTypes.h
+++ b/llvm/lib/CodeGen/SelectionDAG/LegalizeTypes.h
@@ -795,6 +795,7 @@ private:
 
   bool SoftPromoteHalfOperand(SDNode *N, unsigned OpNo);
   SDValue SoftPromoteHalfOp_BITCAST(SDNode *N);
+  SDValue SoftPromoteHalfOp_BR_CC(SDNode *N, unsigned OpNo);
   SDValue SoftPromoteHalfOp_FAKE_USE(SDNode *N, unsigned OpNo);
   SDValue SoftPromoteHalfOp_FCOPYSIGN(SDNode *N, unsigned OpNo);
   SDValue SoftPromoteHalfOp_FP_EXTEND(SDNode *N);
