From 2085f982f0e4b459783232ef8388b26c899a617f Mon Sep 17 00:00:00 2001
From: Jacob Lambert <jacob.lambert@amd.com>
Date: Thu, 30 Apr 2026 11:19:05 -0700
Subject: [PATCH] [Comgr] Error on BC_BUNDLE input to LINK_BC_TO_BC

Follow-up to eb04fc540 ([Comgr] Remove silent undbundle path from
LINK_BC_TO_BC). After that commit, BC_BUNDLE inputs were silently
skipped, which can cause callers to produce code objects with missing
kernels and very confusing runtime symbol-lookup failures.

Make the action return AMD_COMGR_STATUS_ERROR_INVALID_ARGUMENT with a
clear log message instead, so any caller that still passes a bundle
into LINK_BC_TO_BC fails loudly at the link step. Callers should
unbundle first via AMD_COMGR_ACTION_UNBUNDLE.
---
 amd/comgr/src/comgr-compiler.cpp | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/amd/comgr/src/comgr-compiler.cpp b/amd/comgr/src/comgr-compiler.cpp
index 3cf95c69a29d..f6ceb5fafaaa 100644
--- a/amd/comgr/src/comgr-compiler.cpp
+++ b/amd/comgr/src/comgr-compiler.cpp
@@ -1488,8 +1488,17 @@ amd_comgr_status_t AMDGPUCompiler::linkBitcodeToBitcode() {
       }
     }
 
+    if (Input->DataKind == AMD_COMGR_DATA_KIND_BC_BUNDLE) {
+      LogS << "Error: AMD_COMGR_ACTION_LINK_BC_TO_BC received a bundled "
+              "bitcode input ('"
+           << Input->Name
+           << "'). Bundled bitcodes must be unbundled (via "
+              "AMD_COMGR_ACTION_UNBUNDLE) before linking.\n";
+      return AMD_COMGR_STATUS_ERROR_INVALID_ARGUMENT;
+    }
+
     if (Input->DataKind != AMD_COMGR_DATA_KIND_BC) {
-      continue; 
+      continue;
     }
 
     if (env::shouldEmitVerboseLogs()) {
