From d319c9310ca117c9888cedacf61a1962b021f62f Mon Sep 17 00:00:00 2001
From: Jacob Lambert <jacob.lambert@amd.com>
Date: Thu, 30 Apr 2026 16:04:51 -0700
Subject: [PATCH] [Comgr] Error on any non-BC input to LINK_BC_TO_BC

Follow-up to eb04fc540 ([Comgr] Remove silent undbundle path from
LINK_BC_TO_BC). After that commit, non-BC inputs (BC_BUNDLE, AR_BUNDLE)
were silently skipped, which can cause callers to produce code objects
with missing kernels and confusing runtime symbol-lookup failures.

Make the action return AMD_COMGR_STATUS_ERROR_INVALID_ARGUMENT with a
clear log message including the DataKind value, so any caller that
still passes non-BC inputs into LINK_BC_TO_BC fails loudly at the link
step. Callers should unbundle first via AMD_COMGR_ACTION_UNBUNDLE.
---
 amd/comgr/src/comgr-compiler.cpp | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/amd/comgr/src/comgr-compiler.cpp b/amd/comgr/src/comgr-compiler.cpp
index 3cf95c69a29d..6281a91decdd 100644
--- a/amd/comgr/src/comgr-compiler.cpp
+++ b/amd/comgr/src/comgr-compiler.cpp
@@ -1489,7 +1489,13 @@ amd_comgr_status_t AMDGPUCompiler::linkBitcodeToBitcode() {
     }
 
     if (Input->DataKind != AMD_COMGR_DATA_KIND_BC) {
-      continue; 
+      LogS << "Error: AMD_COMGR_ACTION_LINK_BC_TO_BC received a non-BC "
+              "input ('"
+           << Input->Name << "', DataKind=" << Input->DataKind
+           << "). Bundled bitcodes (BC_BUNDLE) and archive bundles "
+              "(AR_BUNDLE) must be unbundled (via "
+              "AMD_COMGR_ACTION_UNBUNDLE) before linking.\n";
+      return AMD_COMGR_STATUS_ERROR_INVALID_ARGUMENT;
     }
 
     if (env::shouldEmitVerboseLogs()) {
