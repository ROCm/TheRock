From 03c0dc9a1638266db5df201d4ea45ba6733061d4 Mon Sep 17 00:00:00 2001
From: Philipp Samfass <philipp.samfass@amd.com>
Date: Fri, 20 Feb 2026 14:06:58 +0000
Subject: [PATCH] fix: disable atomic_codegen tests for HIP builds

The atomic_codegen tests require CUDA-specific tools (cuobjdump) that are
not available in HIP builds. This change conditionally enables these tests
only when LIBCUDACXX_ENABLE_CUDA is set, preventing CMake configuration
errors in HIP-only environments.
---
 .upstream-tests/test/CMakeLists.txt | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/.upstream-tests/test/CMakeLists.txt b/.upstream-tests/test/CMakeLists.txt
index 4c535cdf6..2268dba03 100644
--- a/.upstream-tests/test/CMakeLists.txt
+++ b/.upstream-tests/test/CMakeLists.txt
@@ -299,4 +299,7 @@ elseif(LIBCUDACXX_ENABLE_HIP)
   endif()
 endif()
 
-add_subdirectory(atomic_codegen)
+# atomic_codegen tests require CUDA-specific tools (cuobjdump) and are not supported with HIP
+if(LIBCUDACXX_ENABLE_CUDA)
+  add_subdirectory(atomic_codegen)
+endif()
-- 
2.34.1

